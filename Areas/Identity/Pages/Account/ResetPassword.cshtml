@page
@model ResetPasswordModel
@using Recruit_Finder_AI.Services
@inject SettingsService SettingsService
@{
    ViewData["Title"] = "Reset password";
    var settings = await SettingsService.GetAdminSettingsAsync();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Reset Password</h2>
                        <p class="text-muted small">Please enter your new security credentials below.</p>
                    </div>

                    <div class="alert alert-info border-0 shadow-sm rounded-4 py-3 mb-4" style="background-color: #eef2ff;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-info-circle-fill text-primary fs-5 me-3"></i>
                            <small class="text-dark">
                                <strong>Security Policy:</strong> You cannot reuse any of your last <strong>@settings.PasswordHistoryDepth</strong> passwords.
                            </small>
                        </div>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <input asp-for="Input.Code" type="hidden" />

                        <div>
                            <label asp-for="Input.Email" class="form-label small fw-bold text-muted text-uppercase ms-2">Email Address</label>
                            <input asp-for="Input.Email" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small ms-2"></span>
                        </div>

                        <div>
                            <label asp-for="Input.Password" class="form-label small fw-bold text-muted text-uppercase ms-2">New Password</label>
                            <div class="input-group shadow-sm rounded-pill border border-light-subtle bg-white" style="overflow: hidden;">
                                <input asp-for="Input.Password" class="form-control border-0 px-4 py-2 no-emoji bg-transparent shadow-none" autocomplete="new-password" aria-required="true" placeholder="Enter new password" />
                                <button class="btn border-0 bg-transparent pe-4 text-muted d-flex align-items-center toggle-password-btn" type="button" style="box-shadow: none;">
                                    <i class="bi bi-eye toggle-icon" style="cursor: pointer; font-size: 1.1rem;"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase ms-2">Confirm New Password</label>
                            <div class="input-group shadow-sm rounded-pill border border-light-subtle bg-white" style="overflow: hidden;">
                                <input asp-for="Input.ConfirmPassword" class="form-control border-0 px-4 py-2 no-emoji bg-transparent shadow-none" autocomplete="new-password" aria-required="true" placeholder="Repeat new password" />
                                <button class="btn border-0 bg-transparent pe-4 text-muted d-flex align-items-center toggle-password-btn" type="button" style="box-shadow: none;">
                                    <i class="bi bi-eye toggle-icon" style="cursor: pointer; font-size: 1.1rem;"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small ms-2"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mt-2">
                            Reset Password
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-page="./Login" class="text-primary fw-bold text-decoration-none hover-link">
                            Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function removeEmojis(text) {
                if (!text) return '';
                return text.replace(/[^\p{L}\p{N}\p{P}\p{Z}\$\^\r\n]/gu, '');
            }

            document.querySelectorAll('.no-emoji').forEach(el => {
                el.addEventListener('input', e => {
                    const original = e.target.value;
                    const cleaned = removeEmojis(original);
                    if (original !== cleaned) {
                        e.target.value = cleaned;
                    }
                });
            });

            document.querySelectorAll('.toggle-password-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const inputGroup = this.closest('.input-group');
                    const input = inputGroup.querySelector('input');
                    const icon = this.querySelector('.toggle-icon');
                    
                    const isPassword = input.getAttribute('type') === 'password';
                    input.setAttribute('type', isPassword ? 'text' : 'password');
                    
                    if (isPassword) {
                        icon.classList.remove('bi-eye');
                        icon.classList.add('bi-eye-slash');
                    } else {
                        icon.classList.remove('bi-eye-slash');
                        icon.classList.add('bi-eye');
                    }
                });
            });
        });
    </script>
}