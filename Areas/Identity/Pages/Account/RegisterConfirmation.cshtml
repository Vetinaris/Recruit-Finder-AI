@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirm Your Account";
}

<div class="container py-5 text-center">
    <div class="card shadow-lg p-4 mx-auto border-0 rounded-4" style="max-width: 450px;">
        <div class="mb-3">
            <i class="bi bi-patch-check text-primary" style="font-size: 3.5rem;"></i>
        </div>

        <h2 class="fw-bold">Weryfikacja Email</h2>
        <p class="text-muted">
            Wpisz 6-cyfrowy kod wysłany na adres:<br />
            <strong class="text-dark">@Model.Input.Email</strong>
        </p>

        <form method="post" class="mt-4">
            <input type="hidden" asp-for="Input.Email" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-group mb-4">
                <label class="form-label small text-uppercase fw-bold text-muted">Kod weryfikacyjny</label>
                <input asp-for="Input.Code" class="form-control form-control-lg text-center fw-bold"
                       style="font-size: 2.2rem; letter-spacing: 8px; border-radius: 12px; border: 2px solid #eee; height: 70px;"
                       maxlength="6" placeholder="000000" autocomplete="off" />
                <span asp-validation-for="Input.Code" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm py-3 fw-bold">
                Potwierdź i Aktywuj
            </button>
        </form>

        <div class="mt-4 pt-2 border-top">
            <p class="small text-muted mb-1">Nie otrzymałeś kodu?</p>
            <a asp-page="./SendCode" asp-route-email="@Model.Input.Email" class="text-primary fw-bold text-decoration-none">
                <i class="bi bi-arrow-clockwise"></i> Wyślij ponownie
            </a>
        </div>

        <div class="mt-3">
            <p class="small text-muted">
                Podałeś zły email? <a asp-page="./Register" class="text-decoration-none">Zarejestruj się ponownie</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}