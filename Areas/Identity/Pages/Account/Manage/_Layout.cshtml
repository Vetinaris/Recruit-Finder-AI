@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="mb-5">
        <div class="d-flex align-items-center mb-2">
            <h1 class="fw-bold text-dark mb-0">Account Settings</h1>
        </div>
        <p class="text-muted ms-1">Manage your profile, security preferences, and personal data.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-3 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-light-subtle">
                <div class="mb-3 px-3">
                    <small class="text-uppercase fw-bold text-muted" style="letter-spacing: 1px; font-size: 0.75rem;">Menu</small>
                </div>
                <partial name="_ManageNav" />
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white border-light-subtle">
                <div class="card-body p-4 p-md-5">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
