@page
@model ChangePasswordModel
@using Recruit_Finder_AI.Services
@inject SettingsService SettingsService
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;

    var settings = await SettingsService.GetAdminSettingsAsync();
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
    <div class="card-body p-4 p-md-5">
        <div class="row">
            <div class="col-lg-10">
                <div class="alert alert-info border-0 rounded-4 shadow-sm mb-5 p-4 bg-light border-start border-primary border-4">
                    <div class="d-flex align-items-center text-dark">
                        <i class="bi bi-shield-lock-fill fs-3 text-primary me-3"></i>
                        <div>
                            <p class="mb-0 fw-bold">Security Requirement</p>
                            <p class="mb-0 small opacity-75">To protect your account, you cannot reuse any of your <strong>last @settings.PasswordHistoryDepth passwords</strong>.</p>
                        </div>
                    </div>
                </div>

                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div>
                        <label asp-for="Input.OldPassword" class="form-label small fw-bold text-muted text-uppercase ms-2">Current Password</label>
                        <input asp-for="Input.OldPassword" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="current-password" aria-required="true" placeholder="Enter old password" />
                        <span asp-validation-for="Input.OldPassword" class="text-danger small ms-2"></span>
                    </div>

                    <div>
                        <label asp-for="Input.NewPassword" class="form-label small fw-bold text-muted text-uppercase ms-2">New Password</label>
                        <input asp-for="Input.NewPassword" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="new-password" aria-required="true" placeholder="Enter new password" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger small ms-2"></span>
                    </div>

                    <div class="mb-2">
                        <label asp-for="Input.ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase ms-2">Confirm New Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="new-password" aria-required="true" placeholder="Repeat new password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small ms-2"></span>
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                            Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function removeEmojis(text) {
                const regex = /[^\w\s\d.,!@@#$%^&*()\-=_+\[\]{}|;:'"<>\/?\\ąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/gu;
                return text.replace(regex, '');
            }

            document.querySelectorAll('.no-emoji').forEach(el => {
                el.addEventListener('input', e => {
                    const original = e.target.value;
                    const cleaned = removeEmojis(original);
                    if (original !== cleaned) {
                        e.target.value = cleaned;
                    }
                });
                
                el.addEventListener('paste', e => {
                    setTimeout(() => {
                        e.target.value = removeEmojis(e.target.value);
                    }, 0);
                });
            });
        });
    </script>
}