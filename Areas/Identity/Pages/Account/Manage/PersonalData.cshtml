@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="fw-bold mb-4">@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 bg-light rounded-4 p-4 mb-4">
            <div class="d-flex align-items-start">
                <i class="bi bi-info-circle-fill text-primary fs-4 me-3 mt-1"></i>
                <div>
                    <p class="mb-3 text-secondary">
                        Your account contains personal data that you have shared with us to enable AI-powered job matching and recruitment services.
                    </p>
                    <p class="mb-0 text-secondary">
                        You have the right to manage this information, including the permanent removal of your profile from our system.
                    </p>
                </div>
            </div>
        </div>

        <div class="card border-1 border-danger-subtle rounded-4 p-4 shadow-sm">
            <h5 class="fw-bold text-danger mb-3">
                <i class="bi bi-exclamation-octagon me-2"></i>Critical Action
            </h5>
            <p class="small text-muted mb-4">
                <strong>Deleting this data will permanently remove your account.</strong> All your job listings, uploaded CVs, and AI analysis results will be lost forever and cannot be recovered.
            </p>
            
            <div class="d-grid d-md-block">
                <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm">
                    <i class="bi bi-trash3 me-2"></i>Delete My Account
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}