@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="fw-bold mb-4 text-dark">@ViewData["Title"]</h3>

<div class="row">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4" style="border: 1px solid #f8f9fa !important;">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary rounded-circle text-white me-3 d-flex align-items-center justify-content-center"
                         style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="bi bi-info-circle-fill"></i>
                    </div>
                    <h4 class="mb-0 fw-bold text-dark">Account Information</h4>
                </div>

                <div class="bg-light p-4 rounded-4 border border-light-subtle">
                    <p class="mb-3 text-secondary">
                        Your account contains personal data that you have shared with us to enable AI-powered job matching and recruitment services.
                    </p>
                    <p class="mb-0 text-secondary">
                        You have the right to manage this information, including the permanent removal of your profile from our system.
                    </p>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
            <div class="card-body p-4 p-md-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-danger rounded-circle text-white me-3 d-flex align-items-center justify-content-center"
                         style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                    <h4 class="mb-0 fw-bold text-danger">Critical Action</h4>
                </div>

                <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-5 p-4 bg-light border-start border-danger border-4">
                    <p class="small text-dark mb-0">
                        <strong class="text-danger">Deleting this data will permanently remove your account.</strong>
                        All your job listings, uploaded CVs, and AI analysis results will be lost forever and cannot be recovered.
                    </p>
                </div>

                <div class="pt-2">
                    <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                        Delete My Account
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}