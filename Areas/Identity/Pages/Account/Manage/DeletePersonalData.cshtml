@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="fw-bold text-danger mb-4">@ViewData["Title"]</h3>

<div class="alert alert-danger rounded-4 p-4 border-0 mb-4 shadow-sm" role="alert">
    <div class="d-flex">
        <div class="flex-shrink-0">
            <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
        </div>
        <div>
            <h5 class="fw-bold">Permanent Action Warning</h5>
            <p class="mb-0 small opacity-75">
                Deleting this data will permanently remove your account and all associated AI recruitment history, 
                including your posted job offers, matched candidates, and CV analysis reports. 
                <strong>This action cannot be undone.</strong>
            </p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <form id="delete-user" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>
            
            @if (Model.RequirePassword)
            {
                <div class="form-floating mb-4">
                    <input asp-for="Input.Password" class="form-control rounded-3 border-danger-subtle" autocomplete="current-password" aria-required="true" placeholder="Enter your password to confirm" />
                    <label asp-for="Input.Password" class="form-label text-muted">Confirm with Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    <div class="form-text mt-2 small text-muted">
                        For security reasons, please enter your password to authorize this permanent deletion.
                    </div>
                </div>
            }
            
            <div class="d-grid d-md-block">
                <button class="btn btn-danger btn-lg rounded-pill px-5 shadow-sm hover-shake" type="submit">
                    <i class="bi bi-trash3 me-2"></i>Delete My Data & Account
                </button>
                <a asp-page="./Index" class="btn btn-light btn-lg rounded-pill px-4 ms-md-2 mt-2 mt-md-0">Cancel</a>
            </div>
        </form>
    </div>
</div>

<style>
    .hover-shake:hover {
        animation: shake 0.5s;
        animation-iteration-count: infinite;
    }

    @@keyframes shake {
        0% { transform: translate(1px, 1px) rotate(0deg); }
        10% { transform: translate(-1px, -2px) rotate(-1deg); }
        20% { transform: translate(-3px, 0px) rotate(1deg); }
        30% { transform: translate(3px, 2px) rotate(0deg); }
        40% { transform: translate(1px, -1px) rotate(1deg); }
        50% { transform: translate(-1px, 2px) rotate(-1deg); }
        60% { transform: translate(-3px, 1px) rotate(0deg); }
        70% { transform: translate(3px, 1px) rotate(-1deg); }
        80% { transform: translate(-1px, -1px) rotate(1deg); }
        90% { transform: translate(1px, 2px) rotate(0deg); }
        100% { transform: translate(1px, -2px) rotate(-1deg); }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}