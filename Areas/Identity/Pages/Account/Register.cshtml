@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center g-5">
        <div class="col-lg-6 d-none d-lg-block">
            <div class="pe-lg-5">
                <h1 class="display-5 fw-bold text-primary mb-4">Join the future of <span class="text-dark">Hiring.</span></h1>
                <ul class="list-unstyled">
                    <li class="mb-4 d-flex align-items-start">
                        <div class="bg-soft-success rounded-circle p-2 me-3 mt-1 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-check-lg text-success fw-bold"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">AI-Powered Screening</h5>
                            <p class="text-muted">Automatically rank candidates based on skill relevance.</p>
                        </div>
                    </li>
                    <li class="mb-4 d-flex align-items-start">
                        <div class="bg-soft-success rounded-circle p-2 me-3 mt-1 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-check-lg text-success fw-bold"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Unlimited Job Postings</h5>
                            <p class="text-muted">Manage all your vacancies in one smart dashboard.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-lg-5 col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-5">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-person-plus-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Create Account</h2>
                        <p class="text-muted small">Fill in the details to get started</p>
                    </div>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div>
                            <label asp-for="Input.Email" class="form-label small fw-bold text-muted text-uppercase ms-2">Email Address</label>
                            <input asp-for="Input.Email" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small ms-2"></span>
                        </div>

                        <div>
                            <label asp-for="Input.Password" class="form-label small fw-bold text-muted text-uppercase ms-2">Password</label>
                            <input asp-for="Input.Password" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="new-password" aria-required="true" placeholder="Create a password" />
                            <span asp-validation-for="Input.Password" class="text-danger small ms-2"></span>
                        </div>

                        <div>
                            <label asp-for="Input.ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase ms-2">Confirm Password</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="new-password" aria-required="true" placeholder="Repeat password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small ms-2"></span>
                        </div>

                        <div class="form-check mb-4 ms-2">
                            <input class="form-check-input" type="checkbox" asp-for="Input.AcceptTerms" id="acceptTerms" required style="cursor:pointer;" />
                            <label class="form-check-label small text-muted" for="acceptTerms" style="cursor:pointer;">
                                I agree to the
                                <a asp-controller="Home" asp-action="TermsOfService" class="text-primary text-decoration-none fw-bold hover-link">Terms of Service</a>
                                and
                                <a asp-controller="Home" asp-action="Privacy" class="text-primary text-decoration-none fw-bold hover-link">Privacy Policy</a>.
                            </label>
                            <div><span asp-validation-for="Input.AcceptTerms" class="text-danger small"></span></div>
                        </div>

                        <button id="registerSubmit" type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mb-4">
                            Sign Up
                        </button>
                    </form>

                    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="divider d-flex align-items-center my-4">
                            <div class="line"></div>
                            <span class="mx-3 text-muted small fw-bold text-uppercase">or</span>
                            <div class="line"></div>
                        </div>
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-outline-light text-dark border rounded-pill shadow-sm py-2 hover-lift fw-medium" name="provider" value="@provider.Name">
                                        <i class="bi bi-google me-2"></i> Continue with @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }

                    <div class="text-center">
                        <p class="small text-muted mb-0">
                            Already have an account?
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none hover-link">Sign In</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function removeEmojis(text) {
                const regex = /[^\w\s\d.,!@@#$%^&*()\-=_+\[\]{}|;:'"<>\/?\\ąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/gu;
                return text.replace(regex, '');
            }

            document.querySelectorAll('.no-emoji').forEach(el => {
                el.addEventListener('input', e => {
                    const original = e.target.value;
                    const cleaned = removeEmojis(original);
                    if (original !== cleaned) {
                        e.target.value = cleaned;
                    }
                });
            });
        });
    </script>
}