@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Confirm Reset Code";
}

<div class="container py-5 text-center">
    <div class="card shadow-lg p-4 mx-auto border-0 rounded-4" style="max-width: 450px;">
        <div class="mb-3">
            <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
        </div>

        <h2 class="fw-bold">Enter Reset Code</h2>
        <p class="text-muted small">We've sent a 6-digit code to <strong>@Model.Input.Email</strong></p>

        @if (TempData["StatusMessage"] != null)
        {
            <div class="alert alert-success small py-2" role="alert">
                @TempData["StatusMessage"]
            </div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Email" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-group mb-4">
                <input asp-for="Input.Code" class="form-control form-control-lg text-center fw-bold"
                       style="font-size: 2.2rem; letter-spacing: 10px; border-radius: 12px; border: 2px solid #eee;"
                       maxlength="6" placeholder="000000" autocomplete="off" />
                <span asp-validation-for="Input.Code" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm py-3 fw-bold mb-3">
                Verify & Change Password
            </button>
        </form>

        <div class="mt-3 pt-3 border-top">
            <p class="small text-muted mb-1">Didn't receive the code?</p>
            <form method="post" asp-page-handler="Resend">
                <input type="hidden" asp-for="Input.Email" />
                <button type="submit" class="btn btn-link text-primary fw-bold text-decoration-none p-0">
                    <i class="bi bi-arrow-clockwise"></i> Didn't get a code? Resend
                </button>
            </form>
        </div>

        <div class="mt-3">
            <a asp-page="./ForgotPassword" class="text-muted small text-decoration-none">Back to email entry</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}