@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Confirm Reset Code";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-4">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Enter Reset Code</h2>
                        <p class="text-muted small">
                            We've sent a 6-digit code to <br />
                            <span class="text-primary fw-bold">@Model.Input.Email</span>
                        </p>
                    </div>

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success small py-2 text-center mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-1"></i> @TempData["StatusMessage"]
                        </div>
                    }

                    <form method="post">
                        <input type="hidden" asp-for="Input.Email" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center" role="alert"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Input.Code" class="form-label small fw-bold text-muted text-uppercase d-block text-center">Verification Code</label>
                            <input asp-for="Input.Code"
                                   class="form-control form-control-lg text-center fw-bold rounded-4 shadow-sm"
                                   style="font-size: 2rem; letter-spacing: 8px; height: 70px;"
                                   maxlength="6"
                                   placeholder="000000"
                                   autocomplete="off" />
                            <span asp-validation-for="Input.Code" class="text-danger small d-block text-center mt-2"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mb-3">
                            Verify & Change Password
                        </button>
                    </form>

                    <div class="mt-4 pt-3 border-top text-center">
                        <p class="small text-muted mb-1">Didn't receive the code?</p>
                        <form method="post" asp-page-handler="Resend">
                            <input type="hidden" asp-for="Input.Email" />
                            <button type="submit" class="btn btn-link text-primary fw-bold text-decoration-none p-0 small hover-link">
                                <i class="bi bi-arrow-clockwise"></i> Resend code
                            </button>
                        </form>
                    </div>

                    <div class="text-center mt-3">
                        <a asp-page="./ForgotPassword" class="text-muted text-decoration-none small hover-link">
                            <i class="bi bi-arrow-left me-1"></i> Back to email entry
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}