@page
@{
    ViewData["Title"] = "Password Reset Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5 text-center">
                    
                    <div class="mb-4">
                        <div class="bg-success text-white mb-4 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-check2-all"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Success!</h2>
                        <p class="text-muted">
                            Your password has been reset successfully. <br />
                            Your account is now secure and ready to use.
                        </p>
                    </div>

                    <div class="mt-4">
                        <a asp-page="./Login" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold py-2 text-decoration-none d-block">
                            Sign In to Your Account
                        </a>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="small text-muted mb-0">
                            Need help? <a href="#" class="text-primary text-decoration-none fw-bold hover-link">Contact Support</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
