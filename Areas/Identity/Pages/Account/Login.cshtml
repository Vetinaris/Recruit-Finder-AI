@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-5">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Welcome Back</h2>
                        <p class="text-muted">Log in to manage your AI recruitment</p>
                    </div>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4" role="alert"></div>
                        
                        <div>
                            <label asp-for="Input.Email" class="form-label small fw-bold text-muted text-uppercase ms-2">Email Address</label>
                            <input asp-for="Input.Email" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small ms-2"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Input.Password" class="form-label small fw-bold text-muted text-uppercase ms-2">Password</label>
                            <input asp-for="Input.Password" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji" autocomplete="current-password" aria-required="true" placeholder="Enter your password" />
                            <span asp-validation-for="Input.Password" class="text-danger small ms-2"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" style="cursor:pointer;" />
                                <label class="form-check-label small text-muted" asp-for="Input.RememberMe" style="cursor:pointer;">
                                    Remember me
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-primary fw-bold text-decoration-none hover-link">Forgot password?</a>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mb-4">
                            Sign In
                        </button>
                        
                        <div class="text-center">
                            <p class="small text-muted mb-0">
                                Don't have an account?
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none hover-link">Register here</a>
                            </p>
                        </div>
                    </form>

                    @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                    {
                        <div class="divider d-flex align-items-center my-4">
                            <div class="line"></div>
                            <span class="mx-3 text-muted small fw-bold text-uppercase">or</span>
                            <div class="line"></div>
                        </div>
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-outline-light text-dark border rounded-pill shadow-sm py-2 hover-lift fw-medium" name="provider" value="@provider.Name">
                                        <img src="~/images/google-icon.svg" width="18" class="me-2" onerror="this.style.display='none'" />
                                        Continue with @provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function removeEmojis(text) {
                const regex = /[^\w\s\d.,!@@#$%^&*()\-=_+\[\]{}|;:'"<>\/?\\ąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/gu;
                return text.replace(regex, '');
            }

            document.querySelectorAll('.no-emoji').forEach(el => {
                el.addEventListener('input', e => {
                    const original = e.target.value;
                    const cleaned = removeEmojis(original);
                    if (original !== cleaned) {
                        e.target.value = cleaned;
                    }
                });
            });
        });
    </script>
}