@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-5">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-key-fill"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Trouble logging in?</h2>
                        <p class="text-muted small">Enter your email and we'll send you a link to reset your password and get back to your AI dashboard.</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-4" role="alert"></div>
                        
                        <div>
                            <label asp-for="Input.Email" class="form-label small fw-bold text-muted text-uppercase ms-2">Email Address</label>
                            <input asp-for="Input.Email" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2 no-emoji"
                                   autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small ms-2"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mb-3">
                            Send Reset Link
                        </button>
                    </form>

                    <div class="text-center mt-2">
                        <a asp-page="./Login" class="text-primary text-decoration-none small fw-bold hover-link">
                            <i class="bi bi-arrow-left me-1"></i> Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function removeEmojis(text) {
                const regex = /[^\w\s\d.,!@@#$%^&*()\-=_+\[\]{}|;:'"<>\/?\\ąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/gu;
                return text.replace(regex, '');
            }

            document.querySelectorAll('.no-emoji').forEach(el => {
                el.addEventListener('input', e => {
                    const original = e.target.value;
                    const cleaned = removeEmojis(original);
                    if (original !== cleaned) {
                        e.target.value = cleaned;
                    }
                });
            });
        });
    </script>
}