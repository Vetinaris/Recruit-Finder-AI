@page
@model SendCodeModel
@{
    ViewData["Title"] = "Verify Your Identity";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f8f9fa !important;">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="text-center mb-5">
                        <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Verify Email</h2>
                        <p class="text-muted small">
                            Account created for <strong class="text-dark">@Model.Email</strong>. <br />
                            Click the button below to receive your 6-digit security code.
                        </p>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Email" />
                        
                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow hover-lift fw-bold mb-3">
                            Get Verification Code
                        </button>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="small text-muted mb-0">
                            Wrong email?
                            <a asp-page="./Register" class="text-primary text-decoration-none fw-bold hover-link">
                                Start over
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
