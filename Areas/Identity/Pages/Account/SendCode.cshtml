@page
@model SendCodeModel
@{
    ViewData["Title"] = "Verify Your Identity";
}

<div class="container py-5 text-center">
    <div class="card shadow-lg p-5 mx-auto border-0 rounded-4" style="max-width: 500px;">
        <div class="mb-4">
            <i class="bi bi-shield-check text-primary display-4"></i>
        </div>
        <h2 class="fw-bold">Step 2: Verify Email</h2>
        <p class="text-muted mb-4">
            Account created for <strong>@Model.Email</strong>. <br />
            Click the button below to receive your 6-digit security code.
        </p>

        <form method="post">
            <input type="hidden" asp-for="Email" />
            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm">
                Get Verification Code
            </button>
        </form>

        <div class="mt-4">
            <p class="small text-muted">
                Wrong email? <a asp-page="./Register" class="text-decoration-none">Start over</a>
            </p>
        </div>
    </div>
</div>