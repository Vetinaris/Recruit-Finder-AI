@model IEnumerable<Recruit_Finder_AI.Entities.Notification>

<div class="container py-5">
    <h2 class="mb-4"><i class="bi bi-envelope-paper me-2 text-primary"></i>Your Messages</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info rounded-4 shadow-sm border-0">
            <i class="bi bi-info-circle me-2"></i> You have no notifications at the moment.
        </div>
    }
    else
    {
        <div class="list-group shadow-sm rounded-4 overflow-hidden border-0">
            @foreach (var item in Model)
            {
                <div class="list-group-item list-group-item-action p-4 @(item.IsCompleted ? "bg-light opacity-75" : "bg-white border-primary border-start border-4")">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <h5 class="mb-1 fw-bold @(item.IsCompleted ? "text-secondary" : "text-dark")">@item.Title</h5>
                        <small class="text-muted">@item.CreatedAt.ToString("g")</small>
                    </div>
                    <p class="mb-2 text-secondary">@item.Content</p>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            @if (!string.IsNullOrEmpty(item.ActionUrl))
                            {
                                <a href="@item.ActionUrl" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2">
                                    View Details
                                </a>
                            }
                        </div>

                        @if (!item.IsCompleted)
                        {
                            <form asp-action="MarkAsCompleted" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm @(User.IsInRole("ADMIN") || User.IsInRole("MODERATOR") ? "btn-success" : "btn-outline-secondary") rounded-pill px-3">
                                    <i class="bi bi-check2-circle me-1"></i>
                                    @if (User.IsInRole("ADMIN") || User.IsInRole("MODERATOR"))
                                    {
                                        <span>Mark as Done</span>
                                    }
                                    else
                                    {
                                        <span>Mark as read</span>
                                    }
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="badge @(User.IsInRole("ADMIN") || User.IsInRole("MODERATOR") ? "bg-success" : "bg-secondary") rounded-pill px-3 shadow-sm">
                                <i class="bi bi-check-lg me-1"></i>
                                @(User.IsInRole("ADMIN") || User.IsInRole("MODERATOR") ? "Completed" : "Read")
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>