@model Recruit_Finder_AI.Models.Cv

@{
    ViewData["Title"] = "CV Details";
    var displayTitle = $"{Model.Name} {Model.Surname}";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">My Resumes</a></li>
            <li class="breadcrumb-item active">@displayTitle</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h2 class="fw-bold mb-0 text-dark">@displayTitle</h2>
                    @if (Model.IsVerified)
                    {
                        <span class="badge rounded-pill bg-success-soft text-success border border-success border-opacity-25 px-3 py-2">
                            <i class="bi bi-patch-check-fill me-1"></i> AI Verified
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-warning-soft text-warning border border-warning border-opacity-25 px-3 py-2 animate-pulse">
                            <i class="bi bi-cpu-fill me-1"></i> AI Processing
                        </span>
                    }
                </div>

                <div class="card-body p-4">
                    <div class="mb-4 text-muted small">
                        <i class="bi bi-calendar3 me-2"></i>Last updated: @Model.CreatedAt.ToString("f")
                    </div>
                    <div class="row g-3 mb-5">
                        <div class="col-12">
                            <h5 class="text-primary fw-bold mb-3 border-bottom pb-2">Personal Information</h5>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 text-muted small uppercase fw-bold">Email Address</p>
                            <p class="fw-medium">@Model.Email</p>

                            <p class="mb-1 text-muted small uppercase fw-bold">Phone Number</p>
                            <p class="fw-medium">@Model.PhoneNumber</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1 text-muted small uppercase fw-bold">Location</p>
                            <p class="fw-medium">@Model.Address</p>

                            <p class="mb-1 text-muted small uppercase fw-bold">Date of Birth</p>
                            <p class="fw-medium">@Model.DateOfBirth</p>
                        </div>
                    </div>

                    <div class="mb-5">
                        <h5 class="text-primary fw-bold mb-3 border-bottom pb-2">Professional Experience</h5>
                        <div class="bg-light p-4 rounded-4" style="white-space: pre-wrap;">@Model.ProfessionalExperience</div>
                    </div>

                    <div class="mb-5">
                        <h5 class="text-primary fw-bold mb-3 border-bottom pb-2">Education</h5>
                        <div class="bg-light p-4 rounded-4" style="white-space: pre-wrap;">@Model.Education</div>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <h5 class="text-primary fw-bold mb-3 border-bottom pb-2">Skills</h5>
                            <div class="bg-light p-3 rounded-4 h-100">@Model.Skills</div>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-primary fw-bold mb-3 border-bottom pb-2">Languages</h5>
                            <div class="bg-light p-3 rounded-4 h-100">@Model.Languages</div>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark">Portfolio / Links</h6>
                            <p class="text-muted">
                                @if (!string.IsNullOrEmpty(Model.Portfolio))
                                {
                                    <a href="@Model.Portfolio" target="_blank" class="text-decoration-none"><i class="bi bi-link-45deg"></i> @Model.Portfolio</a>
                                }
                                else
                                {
                                    <span>No portfolio provided</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark">Interests</h6>
                            <p class="text-muted">@Model.Interests</p>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 p-4">
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-pencil me-2"></i>Edit Resume
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to List</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 bg-soft-primary mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-robot fs-2 text-primary me-2"></i>
                        <h5 class="fw-bold mb-0">AI Feedback</h5>
                    </div>

                    @if (Model.IsVerified && !string.IsNullOrEmpty(Model.AiFeedback))
                    {
                        <div class="p-3 bg-white rounded-3 shadow-sm border-start border-primary border-4">
                            <p class="small text-dark mb-0" style="line-height: 1.5;">@Model.AiFeedback</p>
                        </div>
                    }
                    else if (!Model.IsVerified)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border text-primary spinner-border-sm mb-2" role="status"></div>
                            <p class="small text-muted mb-0">AI is currently analyzing your resume. Check back in a few seconds.</p>
                        </div>
                    }
                    else
                    {
                        <p class="small text-muted mb-0">No specific feedback available at this time.</p>
                    }
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this CV?')">
                <button type="submit" class="btn btn-outline-danger w-100 rounded-pill">
                    <i class="bi bi-trash me-2"></i>Delete CV
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .uppercase {
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }

        100% {
            opacity: 1;
        }
    }
</style>