@using System.Text.Encodings.Web
@model IEnumerable<Recruit_Finder_AI.Models.Cv>
@{
    ViewData["Title"] = "My Resumes";
    int maxCvs = 5;
    int currentCount = Model.Count();
    int remaining = maxCvs - currentCount;
}

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="fw-bold display-6 mb-1">My CV Portfolio</h1>
            <p class="text-muted">
                Manage your resumes. You can have up to <span class="fw-bold text-primary">@maxCvs</span> different versions.
            </p>
        </div>
        <div class="col-md-6 text-md-end">
            @if (currentCount < maxCvs)
            {
                <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill shadow-sm hover-lift px-4">
                    <i class="bi bi-file-earmark-plus-fill me-2"></i>Create New CV
                </a>
            }
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center bg-white p-3 rounded-4 border shadow-sm">
                <div class="me-3">
                    <span class="badge bg-primary rounded-pill px-3 py-2">@currentCount / @maxCvs Used</span>
                </div>
                <div class="progress flex-grow-1" style="height: 12px; border-radius: 10px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                         role="progressbar"
                         style="width: @(currentCount * 20)%"></div>
                </div>
                <div class="ms-3 small fw-bold text-muted">
                    @remaining Left
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="py-5">
                    <i class="bi bi-file-earmark-text text-muted opacity-25" style="font-size: 5rem;"></i>
                    <h3 class="mt-3 fw-bold text-muted">No CVs found</h3>
                    <p class="text-muted">Create your first professional resume to start applying for jobs!</p>
                    <a asp-action="Create" class="btn btn-outline-primary rounded-pill mt-2">Get Started</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var cv in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 hover-lift h-100">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="icon-shape bg-soft-primary text-primary rounded-3" style="width: 50px; height: 50px;">
                                    <i class="bi bi-person-badge fs-3"></i>
                                </div>

                                <div id="status-container-@cv.Id">
                                    @if (cv.IsVerified)
                                    {
                                        <span class="badge rounded-pill bg-success-soft text-success border border-success border-opacity-25">
                                            <i class="bi bi-patch-check-fill me-1"></i> Verified
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning-soft text-warning border border-warning border-opacity-25 animate-pulse">
                                            <i class="bi bi-cpu-fill me-1"></i> AI Processing
                                        </span>
                                    }
                                </div>

                                <div class="dropdown">
                                    <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@cv.Id"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@cv.Id" method="post" onsubmit="return confirm('Are you sure?')">
                                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Delete</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                            <h5 class="fw-bold mb-0 text-truncate">@cv.Name @cv.Surname</h5>

                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar3 me-1"></i>@cv.CreatedAt.ToString("dd MMM yyyy")
                            </p>

                            <div class="bg-light p-3 rounded-3 mb-4 flex-grow-1" style="height: 100px; overflow: hidden; position: relative;">
                                <small class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 0.65rem;">Experience Preview</small>
                                <p class="small text-muted mb-0">@cv.ProfessionalExperience</p>
                                <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 30px; background: linear-gradient(transparent, #f8f9fa);"></div>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@cv.Id" class="btn btn-outline-primary rounded-pill btn-sm flex-grow-1 fw-bold">
                                    <i class="bi bi-eye me-1"></i> Details
                                </a>

                                <form asp-action="Verify" asp-route-id="@cv.Id" method="post" class="flex-grow-1" onsubmit="startLoading(this, '@cv.Id')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" id="verify-btn-@cv.Id"
                                            class="btn btn-soft-info-ai rounded-pill btn-sm w-100 fw-bold"
                                            @(cv.IsVerified ? "disabled" : "")>
                                        <i class="bi bi-robot me-1"></i> @(cv.IsVerified ? "Verified" : "AI Verify")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function startLoading(form, cvId) {
            const btn = document.getElementById(`verify-btn-${cvId}`);
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Processing...';
            }
        }

        function checkPendingStatuses() {
            const pendingBadges = document.querySelectorAll('[id^="status-container-"] .animate-pulse');

            pendingBadges.forEach(badge => {
                const container = badge.parentElement;
                const cvId = container.id.replace('status-container-', '');

                fetch(`/Cv/GetStatus/${cvId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.isVerified) {
                            updateUiToVerified(cvId);
                        }
                    })
                    .catch(err => console.error("Error polling status:", err));
            });
        }

        function updateUiToVerified(cvId) {
            const container = document.getElementById(`status-container-${cvId}`);
            const btn = document.getElementById(`verify-btn-${cvId}`);

            if (container) {
                container.innerHTML = `
                    <span class="badge rounded-pill bg-success-soft text-success border border-success border-opacity-25 animate-in">
                        <i class="bi bi-patch-check-fill me-1"></i> Verified
                    </span>`;
            }
            if (btn) {
                btn.disabled = true;
                btn.className = "btn btn-soft-info-ai rounded-pill btn-sm w-100 fw-bold";
                btn.innerHTML = '<i class="bi bi-robot me-1"></i> Verified';
            }
        }

        setInterval(checkPendingStatuses, 3000);
    </script>
}

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }

        100% {
            opacity: 1;
        }
    }

    .animate-in {
        animation: slide-in 0.5s ease-out;
    }

    @@keyframes slide-in {
        from {
            transform: translateY(-5px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .btn-soft-info-ai {
        background-color: rgba(13, 202, 240, 0.1);
        color: #0dcaf0;
        border: 1px solid rgba(13, 202, 240, 0.2);
    }

        .btn-soft-info-ai:hover:not(:disabled) {
            background-color: #0dcaf0;
            color: white;
        }

    .hover-lift {
        transition: all 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .icon-shape {
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>