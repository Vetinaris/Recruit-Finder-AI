@{
    ViewData["Title"] = "Moderator Guidelines";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="d-flex align-items-center mb-5">
                <div class="icon-shape bg-soft-indigo text-indigo rounded-4 me-3" style="width: 60px; height: 60px; font-size: 1.5rem; background-color: rgba(102, 16, 242, 0.1); color: #6610f2;">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div>
                    <h2 class="fw-bold mb-0">Moderator Handbook</h2>
                    <p class="text-muted mb-0">Standard procedures for company verification and platform safety.</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-primary border-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3 d-flex align-items-center text-primary">
                                <i class="bi bi-check-all me-2"></i> Company Verification
                            </h5>
                            <p class="small text-muted mb-3">Your primary task is to review users who applied for <strong>Employer Status</strong>.</p>
                            <ul class="list-group list-group-flush small">
                                <li class="list-group-item border-0 px-0 py-2">
                                    <i class="bi bi-1-circle me-2 text-primary"></i> <strong>Validate NIP:</strong> Cross-reference the NIP number with official government databases (e.g., VIES or National Registry).
                                </li>
                                <li class="list-group-item border-0 px-0 py-2">
                                    <i class="bi bi-2-circle me-2 text-primary"></i> <strong>Approve:</strong> If data is correct, clicking <em>Approve</em> grants permission to post jobs and sends a success notification.
                                </li>
                                <li class="list-group-item border-0 px-0 py-2">
                                    <i class="bi bi-3-circle me-2 text-primary"></i> <strong>Decline:</strong> Use if NIP is invalid or address is incomplete. The user's NIP will be cleared, and they will be asked to re-apply.
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-warning border-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3 d-flex align-items-center text-warning">
                                <i class="bi bi-exclamation-octagon me-2"></i> Security Protocol
                            </h5>
                            <div class="bg-light p-3 rounded-3 mb-3 border-dashed border-2">
                                <h6 class="fw-bold small mb-2"><i class="bi bi-flag-fill me-1"></i> Reporting Fraud</h6>
                                <p class="small text-muted mb-0">
                                    If you detect a <strong>Fake Company</strong> (stolen NIP, non-existent entity), use the <em>Report to Admin</em> function.
                                    This triggers a critical alert to all Administrators for a permanent ban.
                                </p>
                            </div>
                            <div class="alert alert-soft-warning p-2 small mb-0 border-0">
                                <i class="bi bi-info-circle me-1"></i> Reporting a user automatically sends them a suspension notice and locks their verification path.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 text-dark">Ethical Guidelines</h5>
                            <div class="row g-4">
                                <div class="col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-eye-slash fs-4 text-muted me-3"></i>
                                        <div>
                                            <h6 class="fw-bold mb-1">Confidentiality</h6>
                                            <p class="small text-muted mb-0">Do not share company data or NIP numbers outside the Recruit Finder AI platform.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-clock-history fs-4 text-muted me-3"></i>
                                        <div>
                                            <h6 class="fw-bold mb-1">Response Time</h6>
                                            <p class="small text-muted mb-0">Aim to verify pending requests within 24 hours to ensure employer satisfaction.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-chat-dots fs-4 text-muted me-3"></i>
                                        <div>
                                            <h6 class="fw-bold mb-1">Clear Communication</h6>
                                            <p class="small text-muted mb-0">Notifications sent via <em>Decline</em> should be followed by a support message if necessary.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm transition-hover">
                    <i class="bi bi-speedometer2 me-2"></i> Return to Verification Queue
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fc;
    }
    
    .icon-shape {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .border-dashed {
        border-style: dashed !important;
        border-color: #dee2e6 !important;
    }

    .alert-soft-warning {
        background-color: #fff9eb;
        color: #856404;
    }

    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .list-group-item i {
        font-size: 1.1rem;
    }
</style>