@section Styles {
    <link rel="stylesheet" href="~/css/moderator.css" asp-append-version="true" />
}
@{
    ViewData["Title"] = "Moderator Guidelines";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            
            <div class="d-flex align-items-center mb-5">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Moderator Handbook</h2>
                    <p class="text-muted mb-0 small">Standard procedures for company verification and platform safety.</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-lg rounded-4 h-100 border-start border-primary border-5 hover-lift-static">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 d-flex align-items-center text-primary text-uppercase small">
                                <i class="bi bi-check-all me-2"></i> Company Verification
                            </h5>
                            <p class="small text-muted mb-3 ms-2">Your primary task is to review users who applied for <strong>Employer Status</strong>.</p>
                            
                            <ul class="list-group list-group-flush small ms-2">
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-1-circle text-primary me-2"></i> <strong>Validate NIP:</strong> Cross-reference with VIES or National Registry.
                                </li>
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-2-circle text-primary me-2"></i> <strong>Approve:</strong> Grants job posting permissions and sends success alert.
                                </li>
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-3-circle text-primary me-2"></i> <strong>Decline:</strong> Use if NIP is invalid or address is incomplete.
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-lg rounded-4 h-100 border-start border-warning border-5 hover-lift-static">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 d-flex align-items-center text-warning text-uppercase small">
                                <i class="bi bi-exclamation-octagon me-2"></i> Security Protocol
                            </h5>
                            
                            <div class="bg-light p-3 rounded-4 mb-3 border-dashed border-2">
                                <h6 class="fw-bold small mb-2"><i class="bi bi-flag-fill me-1"></i> Reporting Fraud</h6>
                                <p class="small text-muted mb-0">
                                    If you detect a <strong>Fake Company</strong>, use the <em>Report to Admin</em> function.
                                    This triggers a critical alert for a permanent ban.
                                </p>
                            </div>
                            
                            <div class="bg-soft-warning p-3 rounded-4 small mb-0">
                                <i class="bi bi-info-circle-fill text-warning me-2"></i>
                                Reporting a user automatically sends a suspension notice and locks their verification path.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="border: 1px solid #f1f1f1 !important;">
                        <div class="card-body p-4 p-md-5">
                            <h5 class="fw-bold text-dark mb-4 text-center">Ethical Guidelines</h5>
                            <div class="row g-4">
                                <div class="col-md-4 text-center text-md-start border-end border-light-subtle d-flex flex-column align-items-center align-items-md-start">
                                    <div class="icon-circle bg-soft-primary text-primary mb-3" style="width: 50px; height: 50px; font-size: 1.3rem;">
                                        <i class="bi bi-eye-slash"></i>
                                    </div>
                                    <h6 class="fw-bold mb-1">Confidentiality</h6>
                                    <p class="small text-muted mb-0">Do not share company data outside the Recruit Finder AI platform.</p>
                                </div>
                                <div class="col-md-4 text-center text-md-start border-end border-light-subtle d-flex flex-column align-items-center align-items-md-start">
                                    <div class="icon-circle bg-soft-primary text-primary mb-3" style="width: 50px; height: 50px; font-size: 1.3rem;">
                                        <i class="bi bi-clock-history"></i>
                                    </div>
                                    <h6 class="fw-bold mb-1">Response Time</h6>
                                    <p class="small text-muted mb-0">Verify pending requests within 24h to ensure satisfaction.</p>
                                </div>
                                <div class="col-md-4 text-center text-md-start d-flex flex-column align-items-center align-items-md-start">
                                    <div class="icon-circle bg-soft-primary text-primary mb-3" style="width: 50px; height: 50px; font-size: 1.3rem;">
                                        <i class="bi bi-chat-dots"></i>
                                    </div>
                                    <h6 class="fw-bold mb-1">Clear Communication</h6>
                                    <p class="small text-muted mb-0">Decline notifications should be polite and provide clear feedback.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                    Return to Verification Queue
                </a>
            </div>
        </div>
    </div>
</div>
