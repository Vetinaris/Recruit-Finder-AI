@model Recruit_Finder_AI.Models.ApplyViewModel

@{
    ViewData["Title"] = "Select your CV";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-send-check fs-3 me-3"></i>
                        <h4 class="mb-0 fw-bold">Applying for Position</h4>
                    </div>
                    <p class="mb-0 opacity-75">
                        <strong>@Model.JobOffer.Title</strong> @@ @Model.JobOffer.Company
                    </p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="SubmitApplication" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="JobOfferId" />

                        <h5 class="fw-bold mb-3 text-dark">Choose the resume to send:</h5>
                        <div class="list-group mb-4">
                            @foreach (var cv in Model.UserResumes)
                            {
                                <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 p-3 border rounded-3 mb-2 clickable-item shadow-sm">
                                    <input class="form-check-input flex-shrink-0" type="radio"
                                           name="SelectedCvId" value="@cv.Id" required
                                           @(cv == Model.UserResumes.First() ? "checked" : "")>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">@cv.Name @cv.Surname</span>
                                        <span class="small text-muted">
                                            <i class="bi bi-clock-history me-1"></i>Created: @cv.CreatedAt.ToString("dd.MM.yyyy")
                                        </span>
                                    </div>
                                </label>
                            }
                        </div>

                        <div class="mb-4">
                            <label asp-for="Message" class="form-label fw-bold">Message to recruiter (optional)</label>
                            <textarea asp-for="Message" class="form-control rounded-3" rows="4"
                                      placeholder="Write a few words about why you are applying..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill py-3 fw-bold shadow-sm">
                                <i class="bi bi-cloud-arrow-up-fill me-2"></i>Send Application
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.JobOfferId"
                               class="btn btn-link text-secondary text-decoration-none fw-semibold">
                                <i class="bi bi-x-circle me-1"></i>Cancel and Go Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8fafd;
    }

    .clickable-item {
        transition: all 0.2s ease;
        border: 2px solid transparent !important;
    }

        .clickable-item:hover {
            background-color: #f0f7ff;
            border-color: #cfe2ff !important;
            transform: translateY(-2px);
        }

    input[type="radio"]:checked + div span {
        color: #0d6efd !important;
    }

    input[type="radio"]:checked {
        border-color: #0d6efd;
        background-color: #0d6efd;
    }

    .list-group-item-action:focus, .list-group-item-action:hover {
        z-index: 1;
        color: inherit;
        text-decoration: none;
        background-color: #f8f9fa;
    }
</style>