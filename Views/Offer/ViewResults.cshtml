@model IEnumerable<Recruit_Finder_AI.Models.JobApplication>
@{
    ViewData["Title"] = "Applications for Offer";
    var offerTitle = ViewBag.OfferTitle ?? "Job Offer Results";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <a href="javascript:history.back()" class="btn btn-link text-muted p-0 me-3">
                <i class="bi bi-arrow-left fs-4"></i>
            </a>
            <div>
                <h1 class="fw-bold h3 mb-0">Applications</h1>
                <p class="text-muted mb-0">Kandydaci na stanowisko: <strong>@offerTitle</strong></p>
            </div>
        </div>
        <div class="badge bg-primary rounded-pill px-3 py-2">
            Total: @Model.Count()
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Candidate</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Message</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Applied Date</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Status</th>
                        <th class="py-3 text-center text-uppercase small fw-bold text-muted">CV Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people display-4 d-block mb-3 opacity-25"></i>
                                <p>No applications received yet for this offer.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3 bg-soft-primary">
                                        @(app.CandidateId.Substring(0, 2).ToUpper())
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">Candidate</div>
                                        <div class="small text-muted">ID: @app.CandidateId.Substring(0, 8)...</div>
                                    </div>
                                </div>
                            </td>
                            <td style="max-width: 300px;">
                                <div class="text-truncate small" title="@app.Message">
                                    @(string.IsNullOrEmpty(app.Message) ? "No message attached." : app.Message)
                                </div>
                            </td>
                            <td>
                                <div class="small text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @app.AppliedAt.ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusClass = app.Status switch
                                    {
                                                    "Accepted" => "bg-success",
                                                    "Rejected" => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };
                                }
                                <span class="badge rounded-pill @statusClass px-3 py-2">
                                    @app.Status
                                </span>
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm rounded-pill bg-white border p-1">
                                    <a asp-controller="Offer" asp-action="CvView" asp-route-id="@app.CvId"
                                       class="btn btn-link btn-sm text-primary p-2" title="View Full CV">
                                        <i class="bi bi-file-earmark-person fs-5"></i>
                                    </a>

                                    <div class="vr my-2 text-muted opacity-25"></div>

                                    <button class="btn btn-link btn-sm text-success p-2" title="Accept">
                                        <i class="bi bi-check-circle fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: #e7f1ff;
        color: #0d6efd;
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.8rem;
    }
</style>