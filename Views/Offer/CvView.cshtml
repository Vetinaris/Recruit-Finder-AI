@model Recruit_Finder_AI.Models.Cv
@section Styles {
    <link rel="stylesheet" href="~/css/offer.css" />
}
@{
    ViewData["Title"] = "CV Details";
    var displayTitle = $"{Model.Name} {Model.Surname}";
    var offerTitle = ViewBag.OfferTitle ?? "this position";

    List<(string Dates, string Title, string Desc)> ParseSection(string input)
    {
        var result = new List<(string Dates, string Title, string Desc)>();
        if (string.IsNullOrEmpty(input)) return result;

        var entries = input.Split(';', StringSplitOptions.RemoveEmptyEntries);
        foreach (var entry in entries)
        {
            try
            {
                var trimEntry = entry.Trim();
                var dateStart = trimEntry.IndexOf('[');
                var dateEnd = trimEntry.IndexOf(']');
                
                if (dateStart != -1 && dateEnd != -1)
                {
                    var dates = trimEntry.Substring(dateStart + 1, dateEnd - dateStart - 1);
                    var rest = trimEntry.Substring(dateEnd + 1).Trim();
                    var colonIndex = rest.IndexOf(':');
                    var title = colonIndex != -1 ? rest.Substring(0, colonIndex).Trim() : rest;
                    var desc = colonIndex != -1 ? rest.Substring(colonIndex + 1).Trim() : "";
                    
                    result.Add((dates, title, desc));
                }
                else
                {
                    result.Add(("", "Detail", trimEntry));
                }
            }
            catch { continue; }
        }

        return result.OrderByDescending(x =>
        {
            var match = System.Text.RegularExpressions.Regex.Match(x.Dates, @"\d{4}");
            return match.Success ? int.Parse(match.Value) : 0;
        }).ToList();
    }
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-5">
        <a href="javascript:history.back()" class="btn btn-link text-muted p-0 me-3">
            <i class="bi bi-arrow-left fs-4"></i>
        </a>
        <div>
            <h1 class="fw-bold h3 mb-0">Applications</h1>
            <p class="text-muted mb-0">Candidates for position: <strong>@offerTitle</strong></p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                    <h2 class="fw-bold mb-0 text-dark">@displayTitle</h2>
                </div>

                <div class="card-body p-4">
                    <div class="mb-4 text-muted small">
                        <i class="bi bi-calendar3 me-2"></i>Received on: @Model.CreatedAt.ToString("f")
                    </div>

                    <div class="row g-3 mb-5 p-3 rounded-4 bg-light border-start border-primary border-4">
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1 d-block">Email Address</label>
                            <p class="fw-medium mb-3">@Model.Email</p>

                            <label class="text-muted small text-uppercase fw-bold mb-1 d-block">Phone Number</label>
                            <p class="fw-medium mb-0">@Model.PhoneNumber</p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small text-uppercase fw-bold mb-1 d-block">Location</label>
                            <p class="fw-medium mb-3">@Model.Address</p>

                            <label class="text-muted small text-uppercase fw-bold mb-1 d-block">Date of Birth</label>
                            <p class="fw-medium mb-0">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToShortDateString() : "Not provided")</p>
                        </div>
                    </div>

                    <div class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-shape bg-soft-primary text-primary rounded-3 me-2" style="width: 35px; height: 35px;">
                                <i class="bi bi-briefcase-fill"></i>
                            </div>
                            <h5 class="fw-bold mb-0">Professional Experience</h5>
                        </div>
                        <div class="timeline">
                            @foreach (var exp in ParseSection(Model.ProfessionalExperience))
                            {
                                <div class="timeline-item pb-4 ps-4 border-start position-relative">
                                    <div class="timeline-dot bg-primary"></div>
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold text-dark mb-0">@exp.Title</h6>
                                        <span class="badge bg-light text-primary border rounded-pill">@exp.Dates</span>
                                    </div>
                                    <p class="text-muted small mb-0" style="white-space: pre-wrap;">@exp.Desc</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <div class="icon-shape bg-soft-primary text-primary rounded-3 me-2" style="width: 35px; height: 35px;">
                                <i class="bi bi-mortarboard-fill"></i>
                            </div>
                            <h5 class="fw-bold mb-0">Education</h5>
                        </div>
                        <div class="timeline">
                            @foreach (var edu in ParseSection(Model.Education))
                            {
                                <div class="timeline-item pb-4 ps-4 border-start position-relative">
                                    <div class="timeline-dot bg-primary"></div>
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold text-dark mb-0">@edu.Title</h6>
                                        <span class="badge bg-light text-primary border rounded-pill">@edu.Dates</span>
                                    </div>
                                    <p class="text-muted small mb-0" style="white-space: pre-wrap;">@edu.Desc</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Skills</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrEmpty(Model.Skills))
                                {
                                    @foreach (var skill in Model.Skills.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge bg-white border text-dark fw-bold rounded-pill px-3 py-2 shadow-xs">@skill.Trim()</span>
                                    }
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Languages</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrEmpty(Model.Languages))
                                {
                                    @foreach (var lang in Model.Languages.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge bg-white border text-dark fw-bold rounded-pill px-3 py-2 shadow-xs">@lang.Trim()</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark mb-2">Portfolio / Links</h6>
                            @if (!string.IsNullOrEmpty(Model.Portfolio))
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var link in Model.Portfolio.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        var cleanLink = link.Trim();
                                        var url = cleanLink.StartsWith("http") ? cleanLink : "https://" + cleanLink;
                                        <a href="@url" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-xs">
                                            <i class="bi bi-link-45deg me-1"></i>
                                            @(cleanLink.Length > 25 ? cleanLink.Substring(0, 22) + "..." : cleanLink)
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <h6 class="fw-bold text-dark mb-2">Interests</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!string.IsNullOrEmpty(Model.Interests))
                                {
                                    @foreach (var interest in Model.Interests.Split(new[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge bg-white border text-dark fw-bold rounded-pill px-3 py-2 shadow-xs">@interest.Trim()</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 text-center">
                    <div class="p-3 bg-light rounded-4 border mb-3">
                        <h6 class="fw-bold text-dark mb-2">Photo Status</h6>
                        @if (Model.IncludePhoto)
                        {
                            <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i> Photo is included in exports</span>
                        }
                        else
                        {
                            <span class="text-muted small"><i class="bi bi-x-circle me-1"></i> Photo is hidden</span>
                        }
                    </div>
                    <div class="p-3 bg-light rounded-4 border mb-4">
                        <div class="icon-shape bg-soft-danger text-danger rounded-circle mx-auto mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-file-earmark-pdf fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Export CV</h5>
                        <p class="text-muted small mb-4">Download the candidate's resume as a formatted PDF file.</p>
                        <a href="@Url.Action("DownloadCv", "Offer", new { id = Model.Id })"
                               class="btn btn-dark w-100 rounded-pill py-3 fw-bold shadow hover-lift">
                            <i class="bi bi-download me-2"></i>Download PDF
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
