@using System.Text.Encodings.Web
@model IEnumerable<Recruit_Finder_AI.Models.JobOffer>
@section Styles {
    <link rel="stylesheet" href="~/css/offer.css" />
}
@{
    ViewData["Title"] = "My Job Listings";
    bool isVerified = ViewBag.IsVerifiedEmployer ?? false;
    var totalOffers = Model.Count();
}

<div class="container py-5">
    <div class="row align-items-center mb-5 gy-4">
        <div class="col-lg-6 text-center text-lg-start">
            <h1 class="fw-bold display-6 mb-1">My Job Listings</h1>
            <p class="text-muted mb-0">
                You have <span class="fw-bold text-primary">@totalOffers</span> listings in total.
            </p>
        </div>
        
        <div class="col-lg-6">
            <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-end gap-3">
        
                @if (isVerified)
                {
                    <a asp-action="ClosedListings" class="btn btn-light btn-lg rounded-pill px-4 border shadow-sm">
                        Closed Offers
                    </a>
                }
                else
                {
                    <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" title="Verify your profile to access archives">
                        <button class="btn btn-secondary btn-lg rounded-pill px-4 shadow-sm" disabled style="opacity: 0.6; cursor: not-allowed;">
                            <i class="bi bi-lock-fill me-2"></i>Closed Offers
                        </button>
                    </span>
                }

                @if (isVerified)
                {
                    <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                        Post New Offer
                    </a>
                }
                else
                {
                    <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" title="Verify your profile to unlock">
                        <button class="btn btn-secondary btn-lg rounded-pill px-5 shadow-sm fw-bold" disabled style="opacity: 0.6; cursor: not-allowed;">
                            <i class="bi bi-lock-fill me-2"></i>Post New Offer
                        </button>
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table" style="min-width: 800px;">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Offer Details</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Category</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Timeline</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Status</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center pe-4" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-clipboard2-plus text-muted display-1 mb-3 d-block"></i>
                                    <h4 class="fw-bold text-muted">No offers yet</h4>
                                    <p class="text-muted mb-0">Start recruiting today by adding your first position.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        bool isExpired = item.ExpirationDate.HasValue && item.ExpirationDate < DateTime.Now;
                        bool canBeClosed = item.IsVisible && !isExpired;

                        <tr class="@(item.IsVisible && !isExpired ? "" : "bg-light-subtle opacity-75")">
                            <td class="ps-4 py-4">
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-soft-primary text-primary rounded-3 me-3 flex-shrink-0" style="width: 45px; height: 45px;">
                                        <i class="bi bi-briefcase-fill"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6 text-wrap" style="max-width: 250px;">@item.Title</div>
                                        <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i>@item.Location</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 fw-semibold">@item.Category</span>
                            </td>
                            <td class="text-center">
                                <div class="small text-muted">
                                    <div class="text-nowrap"><i class="bi bi-plus-circle me-1 text-primary"></i>@item.CreatedAt.ToString("dd MMM yyyy")</div>
                                    @if (item.ExpirationDate.HasValue)
                                    {
                                        <div class="@(isExpired ? "text-danger fw-bold" : "") text-nowrap">
                                            <i class="bi bi-clock-history me-1"></i>@item.ExpirationDate.Value.ToString("dd MMM yyyy")
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="text-center">
                                @if (isExpired)
                                {
                                    <span class="badge bg-soft-warning text-warning rounded-pill px-3 py-2 border border-success border-opacity-10">Expired</span>
                                }
                                else if (item.IsVisible)
                                {
                                    <span class="badge bg-soft-success text-success rounded-pill px-3 py-2 border border-success border-opacity-10">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-danger text-danger rounded-pill px-3 py-2 border border-success border-opacity-10">Hidden</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group glass-actions">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn action-btn text-info" title="View">
                                        <i class="bi bi-person-lines-fill"></i>
                                    </a>

                                    <div class="vr"></div>

                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn action-btn text-primary" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <div class="vr"></div>

                                    @if (canBeClosed)
                                    {
                                        <button type="button" class="btn action-btn text-warning"
                                                onclick="openCloseModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Close">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn action-btn text-success"
                                                onclick="openReopenModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Reopen">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    }

                                    <div class="vr"></div>

                                    <button type="button" class="btn action-btn text-danger"
                                            onclick="openDeleteModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Delete">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="reopenOfferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 custom-main-shadow rounded-4">
            <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-4">
                <div class="icon-box-circle bg-soft-success text-success mb-4">
                    <i class="bi bi-arrow-clockwise"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Reopen Offer?</h3>
                <p class="text-muted mb-0">
                    You are about to reactivate <br>
                    <span class="small fw-bold text-dark" id="reopenOfferTitle"></span>
                </p>
                <p class="x-small text-muted mt-3">
                    <i class="bi bi-info-circle me-1"></i> It will be visible to candidates for 30 days.
                </p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">
                    Cancel
                </button>
                <form id="reopenOfferForm" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm hover-lift">
                        Yes, Reopen
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="closeOfferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 custom-main-shadow rounded-4">
            <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-4">
                <div class="icon-box-circle bg-soft-warning text-warning mb-4">
                    <i class="bi bi-exclamation-circle-fill"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Close Recruitment?</h3>
                <p class="text-muted mb-0">
                    Are you sure you want to close <br>
                    <span class="small fw-bold text-dark" id="closeOfferTitle"></span>
                </p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">
                    Cancel
                </button>
                <form id="closeOfferForm" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm hover-lift text-white">
                        Yes, Close Now
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteOfferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 custom-main-shadow rounded-4">
            <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-4">
                <div class="icon-box-circle bg-soft-danger text-danger mb-4">
                    <i class="bi bi-trash3-fill"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Delete Offer?</h3>
                <p class="text-muted mb-0">
                    This action is permanent. Remove: <br>
                    <span class="small fw-bold text-dark" id="deleteOfferTitle"></span>
                </p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">
                    Keep Offer
                </button>
                <form id="deleteOfferForm" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm hover-lift">
                        Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openReopenModal(offerId, offerTitle) {
            document.getElementById('reopenOfferTitle').innerText = offerTitle;
            const form = document.getElementById('reopenOfferForm');
            form.action = '/Offer/ReopenOffer/' + offerId;
            new bootstrap.Modal(document.getElementById('reopenOfferModal')).show();
        }

        function openCloseModal(offerId, offerTitle) {
            document.getElementById('closeOfferTitle').innerText = offerTitle;
            const form = document.getElementById('closeOfferForm');
            form.action = '/Offer/CloseOffer/' + offerId;
            new bootstrap.Modal(document.getElementById('closeOfferModal')).show();
        }

        function openDeleteModal(offerId, offerTitle) {
            document.getElementById('deleteOfferTitle').innerText = offerTitle;
            const form = document.getElementById('deleteOfferForm');
            form.action = '/Offer/Delete/' + offerId;
            new bootstrap.Modal(document.getElementById('deleteOfferModal')).show();
        }

        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
        });
    </script>
}
