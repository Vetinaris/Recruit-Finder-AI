@model Recruit_Finder_AI.Models.JobOffer

@{
    ViewData["Title"] = "Edit Offer";
    var categories = new List<string> { "IT", "Marketing", "Finance", "Healthcare", "Education", "Engineering", "Sales", "Customer Service", "Human Resources" };
    var jobTypes = new List<string> { "Full-time", "Part-time", "Contract", "Freelance", "B2B", "Internship" };
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="MyListings" class="btn btn-outline-secondary rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0">Update Job Listing</h2>
            </div>

            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="RecruiterId" />
                        <input type="hidden" asp-for="Company" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div class="row g-4">
                            <div class="col-md-7">
                                <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">General Information</h5>

                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-bold small text-uppercase">Job Title</label>
                                    <input asp-for="Title" class="form-control rounded-3 py-2" placeholder="e.g. Senior C# Developer" />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Category" class="form-label fw-bold small text-uppercase">Category</label>
                                        <select asp-for="Category" class="form-select rounded-3">
                                            @foreach (var cat in categories)
                                            {
                                                <option value="@cat">@cat</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="JobType" class="form-label fw-bold small text-uppercase">Job Type</label>
                                        <select asp-for="JobType" class="form-select rounded-3">
                                            @foreach (var type in jobTypes)
                                            {
                                                <option value="@type">@type</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Location" class="form-label fw-bold small text-uppercase">Location</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                                        <input asp-for="Location" class="form-control rounded-3 border-start-0" placeholder="e.g. Warsaw, Poland or Remote" />
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <div class="p-4 bg-light rounded-4 border h-100 shadow-sm">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-gear-fill me-2 text-primary"></i>Offer Settings</h5>

                                    <div class="mb-4">
                                        <label asp-for="ExpirationDate" class="form-label fw-bold small text-uppercase">Expiration Date</label>
                                        <input asp-for="ExpirationDate" class="form-control rounded-3" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                        <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
                                        <div class="form-text small mt-1 text-muted">
                                            <i class="bi bi-info-circle me-1"></i> Leave blank for no expiration.
                                        </div>
                                    </div>

                                    <h5 class="fw-bold mb-3 border-top pt-3"><i class="bi bi-cash-stack me-2 text-success"></i>Compensation</h5>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-uppercase">Salary Display</label>
                                        <select id="salaryTypeEdit" asp-for="SalaryType" class="form-select rounded-3">
                                            <option value="none">Undisclosed</option>
                                            <option value="negotiable">Negotiable</option>
                                            <option value="fixed">Fixed Monthly</option>
                                            <option value="range">Salary Range</option>
                                        </select>
                                    </div>

                                    <div id="salaryInputsArea" class="@((Model.SalaryType == "none" || Model.SalaryType == "negotiable") ? "d-none" : "")">
                                        <div class="mb-3">
                                            <label id="minLabel" class="small fw-bold">Amount (PLN)</label>
                                            <input asp-for="MinimumSalary" class="form-control rounded-3" type="number" step="0.01" />
                                        </div>
                                        <div id="maxSalBox" class="@(Model.SalaryType != "range" ? "d-none" : "")">
                                            <label class="small fw-bold">Max Salary</label>
                                            <input asp-for="MaximumSalary" class="form-control rounded-3" type="number" step="0.01" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 mt-2">
                                <label asp-for="Description" class="form-label fw-bold text-primary small text-uppercase">Job Description</label>
                                <textarea asp-for="Description" class="form-control rounded-4 shadow-sm" rows="12" placeholder="Write about responsibilities, requirements, and benefits..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-5 pt-4 border-top">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                            <a asp-action="MyListings" class="btn btn-light btn-lg rounded-pill px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const sType = document.getElementById("salaryTypeEdit");
            const inputsArea = document.getElementById("salaryInputsArea");
            const maxBox = document.getElementById("maxSalBox");
            const minLabel = document.getElementById("minLabel");

            function updateFields() {
                const val = sType.value;

                if (val === "none" || val === "negotiable") {
                    inputsArea.classList.add("d-none");
                } else {
                    inputsArea.classList.remove("d-none");
                }

                if (val === "range") {
                    maxBox.classList.remove("d-none");
                    minLabel.innerText = "Min Salary (PLN)";
                } else {
                    maxBox.classList.add("d-none");
                    minLabel.innerText = "Amount (PLN)";
                }
            }

            sType.addEventListener("change", updateFields);
            updateFields();
        });
    </script>
}