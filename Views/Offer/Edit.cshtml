@model Recruit_Finder_AI.Models.JobOffer

@{
    ViewData["Title"] = "Edit Offer";
    var categories = new List<string>
    {
        "IT", "Data Science", "Marketing", "Finance",
        "Healthcare", "Engineering", "Sales", "Customer Service",
        "Human Resources", "Design & Creative", "Logistics",
        "Legal", "Education", "Construction", "Hospitality"
    };
    var jobTypes = new List<string> { "Full-time", "Part-time", "Contract", "Freelance", "B2B", "Internship" };
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="MyListings" class="btn btn-outline-secondary rounded-circle me-3 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0">Update Job Listing</h2>
            </div>

            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" id="editOfferForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="RecruiterId" />
                        <input type="hidden" asp-for="Company" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="IsVisible" />
                        <input type="hidden" asp-for="AiAnalysisStatus" />
                        <input type="hidden" asp-for="AiAnalysisComment" />

                        <div class="row g-4">
                            <div class="col-md-7">
                                <h5 class="fw-bold mb-4 text-primary border-bottom pb-2">General Information</h5>

                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-bold small text-uppercase">Job Title</label>
                                    <input asp-for="Title" class="form-control rounded-3 py-2" placeholder="e.g. Senior C# Developer" />
                                    <span asp-validation-for="Title" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Category" class="form-label fw-bold small text-uppercase">Category</label>
                                        <select asp-for="Category" id="categorySelect" class="form-select rounded-3">
                                            @foreach (var cat in categories)
                                            {
                                                <option value="@cat">@cat</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="Subcategory" class="form-label fw-bold small text-uppercase">Subcategory</label>
                                        <input asp-for="Subcategory" id="subcategoryInput" list="subcategoryList" class="form-control rounded-3" placeholder="e.g. Backend" />
                                        <datalist id="subcategoryList"></datalist>
                                        <span asp-validation-for="Subcategory" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label asp-for="JobType" class="form-label fw-bold small text-uppercase">Job Type</label>
                                        <select asp-for="JobType" class="form-select rounded-3">
                                            @foreach (var type in jobTypes)
                                            {
                                                <option value="@type">@type</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Location" class="form-label fw-bold small text-uppercase">Location</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-muted"></i></span>
                                        <input asp-for="Location" class="form-control rounded-3 border-start-0" placeholder="e.g. Warsaw, Poland or Remote" />
                                    </div>
                                    <span asp-validation-for="Location" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="RequiredLanguages" class="form-label fw-bold small text-uppercase">Required Languages</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-translate text-muted"></i></span>
                                        <input asp-for="RequiredLanguages" id="languagesInput" class="form-control rounded-3 border-start-0" placeholder="e.g. English, Polish, German" />
                                    </div>
                                    <small class="text-muted">Separate multiple languages with commas.</small>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <div class="p-4 bg-light rounded-4 border h-100 shadow-sm">
                                    <h5 class="fw-bold mb-3"><i class="bi bi-gear-fill me-2 text-primary"></i>Offer Settings</h5>

                                    <div class="mb-4">
                                        <label asp-for="ExpirationDate" class="form-label fw-bold small text-uppercase">Expiration Date</label>
                                        <input asp-for="ExpirationDate" class="form-control rounded-3" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                        <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
                                    </div>

                                    <h5 class="fw-bold mb-3 border-top pt-3"><i class="bi bi-cash-stack me-2 text-success"></i>Compensation</h5>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-uppercase">Salary Display</label>
                                        <select id="salaryTypeEdit" asp-for="SalaryType" class="form-select rounded-3">
                                            <option value="none">Undisclosed</option>
                                            <option value="negotiable">Negotiable</option>
                                            <option value="fixed">Fixed Monthly</option>
                                            <option value="range">Salary Range</option>
                                        </select>
                                    </div>

                                    <div id="salaryInputsArea" class="@((Model.SalaryType == "none" || Model.SalaryType == "negotiable") ? "d-none" : "")">
                                        <div class="mb-3">
                                            <label id="minLabel" class="small fw-bold">Amount (EUR)</label>
                                            <input asp-for="MinimumSalary" id="minSalary" class="form-control rounded-3" type="number" step="0.01" />
                                        </div>
                                        <div id="maxSalBox" class="@(Model.SalaryType != "range" ? "d-none" : "")">
                                            <label class="small fw-bold">Max Salary (EUR)</label>
                                            <input asp-for="MaximumSalary" id="maxSalary" class="form-control rounded-3" type="number" step="0.01" />
                                        </div>
                                        <div id="salaryError" class="text-danger small mt-2 d-none">
                                            <i class="bi bi-exclamation-circle me-1"></i>Max salary cannot be less than min salary.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <label asp-for="Requirements" class="form-label fw-bold text-primary small text-uppercase">Technical Requirements</label>
                                <textarea asp-for="Requirements" class="form-control rounded-4 shadow-sm" rows="5" placeholder="Key skills, technologies, and certifications..."></textarea>
                                <span asp-validation-for="Requirements" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-2">
                                <label asp-for="Description" class="form-label fw-bold text-primary small text-uppercase">Job Description</label>
                                <textarea asp-for="Description" class="form-control rounded-4 shadow-sm" rows="10" placeholder="Write about responsibilities, company culture, and benefits..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-5 pt-4 border-top">
                            <button type="submit" id="submitBtn" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift">
                                Save Changes
                            </button>
                            <a asp-action="MyListings" class="btn btn-light btn-lg rounded-pill px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const sType = document.getElementById("salaryTypeEdit");
            const inputsArea = document.getElementById("salaryInputsArea");
            const maxBox = document.getElementById("maxSalBox");
            const minLabel = document.getElementById("minLabel");

            const minInput = document.getElementById("minSalary");
            const maxInput = document.getElementById("maxSalary");
            const errorMsg = document.getElementById("salaryError");
            const submitBtn = document.getElementById("submitBtn");

            const categorySelect = document.getElementById("categorySelect");
            const subcategoryInput = document.getElementById("subcategoryInput");
            const subcategoryList = document.getElementById("subcategoryList");
            const subcatMap = @Html.Raw(Json.Serialize(ViewBag.SubcategoryMap ?? new Dictionary<string, List<string>>()));

            function updateSubcategories(isInitialLoad = false) {
                const selectedCat = categorySelect.value;
                subcategoryList.innerHTML = "";

                if (subcatMap[selectedCat]) {
                    subcatMap[selectedCat].forEach(sub => {
                        const option = document.createElement("option");
                        option.value = sub;
                        subcategoryList.appendChild(option);
                    });
                }

                if (!isInitialLoad) {
                    subcategoryInput.value = "";
                }
            }

            categorySelect.addEventListener("change", () => updateSubcategories(false));
            updateSubcategories(true);

            function validateSalary() {
                if (sType.value === "range") {
                    const min = parseFloat(minInput.value) || 0;
                    const max = parseFloat(maxInput.value) || 0;

                    if (max > 0 && max < min) {
                        errorMsg.classList.remove("d-none");
                        submitBtn.disabled = true;
                    } else {
                        errorMsg.classList.add("d-none");
                        submitBtn.disabled = false;
                    }
                } else {
                    errorMsg.classList.add("d-none");
                    submitBtn.disabled = false;
                }
            }

            function updateFields() {
                const val = sType.value;
                if (val === "none" || val === "negotiable") {
                    inputsArea.classList.add("d-none");
                } else {
                    inputsArea.classList.remove("d-none");
                }

                if (val === "range") {
                    maxBox.classList.remove("d-none");
                    minLabel.innerText = "Min Salary (EUR)";
                } else {
                    maxBox.classList.add("d-none");
                    minLabel.innerText = "Amount (EUR)";
                }
                validateSalary();
            }

            sType.addEventListener("change", updateFields);
            minInput.addEventListener("input", validateSalary);
            maxInput.addEventListener("input", validateSalary);

            updateFields();

            const langInput = document.getElementById("languagesInput");
            langInput.addEventListener("blur", function() {
                if(this.value) {
                    this.value = this.value.split(',').map(s => s.trim()).filter(s => s !== "").join(', ');
                }
            });
        });
    </script>
}