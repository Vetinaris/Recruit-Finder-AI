@model IEnumerable<Recruit_Finder_AI.Models.JobOffer>
@section Styles {
    <link rel="stylesheet" href="~/css/offer.css" />
}
@{
    ViewData["Title"] = ViewBag.CategoryName + " Jobs";
    bool showInactive = ViewBag.ShowInactive ?? false;
    bool isStaff = User.IsInRole("MODERATOR") || User.IsInRole("ADMIN");

    var visibleOffers = Model.Where(item =>
        (isStaff && showInactive) ||
        (item.IsVisible &&
         (!item.User.LockoutEnd.HasValue || item.User.LockoutEnd.Value <= DateTimeOffset.UtcNow) &&
         (!item.ExpirationDate.HasValue || item.ExpirationDate > DateTime.Now))
    ).ToList();
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3">
        <div class="text-center text-md-start">
            <h1 class="fw-bold display-6 mb-1">
                Opportunities in <span class="text-primary">@ViewBag.CategoryName</span>
            </h1>
            <p class="text-muted fs-5 mb-0">Discover your next career move with AI-powered match analysis.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 shadow-sm hover-lift">
            <i class="bi bi-grid-3x3-gap me-2"></i>Browse Categories
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-5 bg-white" style="border: 1px solid #f8f9fa !important;">
        <div class="card-body p-4">
            <form method="get" asp-action="List" class="row g-3">
                <input type="hidden" name="category" value="@ViewBag.CategoryName" />

                <div class="col-lg-5 col-md-12">
                    <label class="form-label small fw-bold text-muted text-uppercase">Keyword Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-light-subtle rounded-start-pill">
                            <i class="bi bi-search text-primary"></i>
                        </span>
                        <input type="text" name="searchString" class="form-control border-light-subtle shadow-sm rounded-end-pill"
                               placeholder="Job title, company..." value="@ViewBag.CurrentSearch" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Subcategory</label>
                    <select name="subcategory" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="">All Specializations</option>
                        @if (ViewBag.Subcategories != null)
                        {
                            foreach (var sub in (List<string>)ViewBag.Subcategories)
                            {
                                <option value="@sub" selected="@(ViewBag.CurrentSubcategory == sub)">@sub</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-4 col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Job Type</label>
                    <select name="jobType" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="">All Types</option>
                        @foreach (var type in new[] { "Full-time", "Part-time", "Contract", "Freelance", "B2B", "Internship" })
                        {
                            <option value="@type" selected="@(ViewBag.CurrentJobType == type)">@type</option>
                        }
                    </select>
                </div>

                <div class="col-lg-3 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Language</label>
                    <select name="language" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="">Any Language</option>
                        @if (ViewBag.Languages != null)
                        {
                            foreach (var lang in (List<string>)ViewBag.Languages)
                            {
                                <option value="@lang" selected="@(ViewBag.CurrentLanguage == lang)">@lang</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-lg-3 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Sort By</label>
                    <select name="sortOrder" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Newest Postings</option>
                        <option value="salary_desc" selected="@(ViewBag.CurrentSort == "salary_desc")">Highest Salary</option>
                        <option value="salary_asc" selected="@(ViewBag.CurrentSort == "salary_asc")">Lowest Salary</option>
                        <option value="title" selected="@(ViewBag.CurrentSort == "title")">A-Z Title</option>
                    </select>
                </div>

                <div class="col-lg-3 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Min Salary (EUR)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-light-subtle rounded-start-pill px-3">€</span>
                        <input type="number" name="minSalary" class="form-control border-light-subtle shadow-sm rounded-end-pill"
                               placeholder="e.g. 5000" value="@ViewBag.CurrentMinSalary" />
                    </div>
                </div>

                <div class="col-lg-3 col-md-12 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill flex-grow-1 shadow-sm fw-bold">
                        Apply
                    </button>
                    <a asp-action="List" asp-route-category="@ViewBag.CategoryName" class="btn btn-light border rounded-pill shadow-sm" title="Reset">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>

                @if (isStaff)
                {
                    <div class="col-12 mt-2">
                        <div class="form-check form-switch p-2 border rounded-pill bg-light d-inline-flex align-items-center" style="padding-left: 3.5em !important;">
                            <input class="form-check-input" type="checkbox" name="showInactive" value="true" id="showInactive"
                            @(showInactive ? "checked" : "") onchange="this.form.submit()">
                            <label class="form-check-label ms-2 fw-semibold" for="showInactive">Show hidden & expired offers</label>
                            <input type="hidden" name="showInactive" value="false" />
                        </div>
                    </div>
                }
            </form>
        </div>
    </div>

    <div class="row g-4">
        @if (!visibleOffers.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light rounded-4 p-5 border border-dashed">
                    <i class="bi bi-search text-muted display-1 mb-4 d-block"></i>
                    <h3 class="fw-bold">No offers found</h3>
                    <p class="text-muted">Try adjusting your filters or keyword.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in visibleOffers)
            {
                bool isExpired = item.ExpirationDate.HasValue && item.ExpirationDate < DateTime.Now;
                bool isAuthorBanned = item.User.LockoutEnd.HasValue && item.User.LockoutEnd.Value > DateTimeOffset.UtcNow;
                bool isInactive = !item.IsVisible || isAuthorBanned || isExpired;

                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm job-card rounded-4 @(isInactive ? "opacity-75 border-dashed-danger" : "")">
                        <div class="card-body p-4 d-flex flex-column">
                            
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex flex-wrap gap-1">
                                    <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">
                                        <i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrEmpty(item.Location) ? "Remote" : item.Location)
                                    </span>
                                    
                                    @if (!string.IsNullOrEmpty(item.Subcategory))
                                    {
                                        <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                            <i class="bi bi-tag me-1"></i>@item.Subcategory
                                        </span>
                                    }

                                    @if (isStaff && isInactive)
                                    {
                                        <div class="w-100 mt-1"></div>
                                        @if (!item.IsVisible)
                                        {
                                            <span class="badge bg-danger">HIDDEN</span>
                                        }
                                        @if (isExpired)
                                        {
                                            <span class="badge bg-warning text-dark">EXPIRED</span>
                                        }
                                        @if (isAuthorBanned)
                                        {
                                            <span class="badge bg-dark text-white">USER BANNED</span>
                                        }
                                    }
                                </div>
                                <small class="text-muted fw-bold text-nowrap">
                                    <i class="bi bi-clock me-1"></i>@(item.JobType ?? "Full-time")
                                </small>
                            </div>

                            <h4 class="card-title fw-bold mb-1">@item.Title</h4>
                            <p class="text-primary fw-semibold mb-3">
                                <i class="bi bi-building me-1"></i>@item.Company
                            </p>

                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <small class="text-muted border rounded-pill px-2 py-1 bg-light" style="font-size: 0.75rem;">
                                    <i class="bi bi-calendar-plus me-1"></i>@item.CreatedAt.ToString("dd.MM.yyyy")
                                </small>

                                @if (item.ExpirationDate.HasValue)
                                {
                                    <small class="border rounded-pill px-2 py-1 @(isExpired ? "bg-soft-danger text-danger border-danger" : "bg-light text-muted")" style="font-size: 0.75rem;">
                                        <i class="bi bi-calendar-x me-1"></i>
                                        @item.ExpirationDate.Value.ToString("dd.MM.yyyy")
                                    </small>
                                }
                            </div>

                            <div class="mb-4">
                                <div class="text-muted small line-clamp-3">@Html.Raw(item.Description)</div>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mt-auto pt-3 border-top">
                                <div class="salary-display">
                                    @if (item.SalaryType == "negotiable")
                                    {
                                        <span class="text-secondary fw-semibold">
                                            <i class="bi bi-chat-dots me-1"></i>Negotiable
                                        </span>
                                    }
                                    else if (item.MinimumSalary.HasValue || item.MaximumSalary.HasValue)
                                    {
                                        <span class="text-success fw-bold fs-5">
                                            <i class="bi bi-cash-stack me-1"></i>
                                            @if (item.MinimumSalary.HasValue && item.MaximumSalary.HasValue)
                                            {
                                                <span>€@item.MinimumSalary?.ToString("N0") - @item.MaximumSalary?.ToString("N0")</span>
                                            }
                                            else if (item.MinimumSalary.HasValue)
                                            {
                                                <span>from €@item.MinimumSalary?.ToString("N0")</span>
                                            }
                                            else
                                            {
                                                <span>up to €@item.MaximumSalary?.ToString("N0")</span>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Salary not specified</span>
                                    }
                                </div>

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary rounded-pill px-4 hover-lift fw-bold shadow-sm">
                                    Details
                                </a>
                            </div>

                            @if (isStaff)
                            {
                                <div class="mt-3 pt-3 border-top d-flex justify-content-center">
                                    <div class="glass-actions px-3">
                                        <div class="btn-group">
                                            @if (item.IsVisible)
                                            {
                                                <button onclick="openVisibilityModal('@item.Id', 'hide', '@item.Title')" class="btn action-btn text-warning w-auto px-3" title="Hide Offer">
                                                    <i class="bi bi-eye-slash-fill me-2"></i><span class="small fw-bold"></span>
                                                </button>
                                            }
                                            else
                                            {
                                                <button onclick="openVisibilityModal('@item.Id', 'show', '@item.Title')" class="btn action-btn text-success w-auto px-3" title="Show Offer">
                                                    <i class="bi bi-eye-fill me-2"></i><span class="small fw-bold"></span>
                                                </button>
                                            }

                                            <div class="vr mx-1"></div>

                                            <button onclick="openFlagModal('@item.Id', '@item.Title')" class="btn action-btn text-danger w-auto px-3" title="Report & Flag">
                                                <i class="bi bi-flag-fill me-2"></i><span class="small fw-bold"></span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade" id="visibilityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 custom-main-shadow rounded-4">
            <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-4">
                <div id="visibilityIcon" class="icon-box-circle mb-4">
                </div>
                <h3 class="fw-bold text-dark mb-2" id="visibilityModalTitle">Change Visibility</h3>
                <p class="text-muted mb-0">Are you sure you want to <span id="visibilityActionText" class="fw-bold"></span> the offer:</p>
                <p class="fw-bold text-dark mt-1" id="visibilityOfferName"></p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">Cancel</button>
                <form id="visibilityForm" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" id="visibilityConfirmBtn" class="btn rounded-pill px-4 fw-bold shadow-sm hover-lift">Confirm</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="flagModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 custom-main-shadow rounded-4">
            <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center px-4 pb-4">
                <div class="icon-box-circle bg-soft-danger text-danger mb-4">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Flag Offer?</h3>
                <p class="text-muted mb-0">This will hide the offer and notify admins of violations for:</p>
                <p class="fw-bold text-dark mt-1" id="flagOfferName"></p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">Cancel</button>
                <form id="flagForm" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm hover-lift">Yes, Flag Offer</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function removeEmojis(text) {
            var regex = /[^\w\s\d.,!@@#$%^&*()\-=_+\[\]{}|;:'"<>\/?\\ąćęłńóśźżĄĆĘŁŃÓŚŹŻ]/gu;
            return text.replace(regex, '');
        }

        $(document).on('input', 'input[type="text"], textarea', function() {
            var originalValue = $(this).val();
            var cleanedValue = removeEmojis(originalValue);
            
            if (originalValue !== cleanedValue) {
                $(this).val(cleanedValue);
            }
        });

        function openVisibilityModal(id, action, title) {
            const form = document.getElementById('visibilityForm');
            const titleElem = document.getElementById('visibilityModalTitle');
            const actionText = document.getElementById('visibilityActionText');
            const offerName = document.getElementById('visibilityOfferName');
            const confirmBtn = document.getElementById('visibilityConfirmBtn');
            const iconContainer = document.getElementById('visibilityIcon');

            offerName.innerText = title;
    
            if (action === 'hide') {
                form.action = '/Offer/HideOffer/' + id;
                titleElem.innerText = 'Hide Offer?';
                actionText.innerText = 'HIDE';
                confirmBtn.className = 'btn btn-warning text-white rounded-pill px-4 fw-bold shadow-sm hover-lift';
                iconContainer.className = 'icon-box-circle bg-soft-warning text-warning mb-4';
                iconContainer.innerHTML = '<i class="bi bi-eye-slash-fill"></i>';
            } else {
                form.action = '/Offer/ShowOffer/' + id;
                titleElem.innerText = 'Show Offer?';
                actionText.innerText = 'SHOW';
                confirmBtn.className = 'btn btn-success rounded-pill px-4 fw-bold shadow-sm hover-lift';
                iconContainer.className = 'icon-box-circle bg-soft-success text-success mb-4';
                iconContainer.innerHTML = '<i class="bi bi-eye-fill"></i>';
            }

            new bootstrap.Modal(document.getElementById('visibilityModal')).show();
        }

        function openFlagModal(id, title) {
            document.getElementById('flagOfferName').innerText = title;
            document.getElementById('flagForm').action = '/Offer/ReportUser/' + id;
            new bootstrap.Modal(document.getElementById('flagModal')).show();
        }
    </script>
}
