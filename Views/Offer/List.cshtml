@model IEnumerable<Recruit_Finder_AI.Models.JobOffer>
@{
    ViewData["Title"] = ViewBag.CategoryName + " Jobs";
    bool showInactive = ViewBag.ShowInactive ?? false;
    bool isStaff = User.IsInRole("MODERATOR") || User.IsInRole("ADMIN");

    var visibleOffers = Model.Where(item =>
        (isStaff && showInactive) ||
        (item.IsVisible &&
         (!item.User.LockoutEnd.HasValue || item.User.LockoutEnd.Value <= DateTimeOffset.UtcNow) &&
         (!item.ExpirationDate.HasValue || item.ExpirationDate > DateTime.Now))
    ).ToList();
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3">
        <div class="text-center text-md-start">
            <h1 class="fw-bold display-6 mb-1">
                Opportunities in <span class="text-primary">@ViewBag.CategoryName</span>
            </h1>
            <p class="text-muted fs-5 mb-0">Discover your next career move with AI-powered match analysis.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 shadow-sm hover-lift">
            <i class="bi bi-grid-3x3-gap me-2"></i>Browse Categories
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-5 bg-white">
        <div class="card-body p-4">
            <form method="get" asp-action="List" class="row g-3 align-items-end">
                <input type="hidden" name="category" value="@ViewBag.CategoryName" />

                <div class="col-lg-3 col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Job Type</label>
                    <select name="jobType" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="">All Types</option>
                        @foreach (var type in new[] { "Full-time", "Part-time", "Contract", "Freelance", "B2B", "Internship" })
                        {
                            <option value="@type" selected="@(ViewBag.CurrentJobType == type)">@type</option>
                        }
                    </select>
                </div>

                <div class="col-lg-3 col-md-6">
                    <label class="form-label small fw-bold text-muted text-uppercase">Salary Type</label>
                    <select name="salaryType" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="">Any Salary Type</option>
                        <option value="none" selected="@(ViewBag.CurrentSalaryType == "none")">Undisclosed</option>
                        <option value="negotiable" selected="@(ViewBag.CurrentSalaryType == "negotiable")">Negotiable</option>
                        <option value="fixed" selected="@(ViewBag.CurrentSalaryType == "fixed")">Fixed Price</option>
                        <option value="range" selected="@(ViewBag.CurrentSalaryType == "range")">Salary Range</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Min. PLN</label>
                    <input type="number" name="minSalary" class="form-control border-light-subtle shadow-sm rounded-pill"
                           placeholder="e.g. 5000" value="@ViewBag.CurrentMinSalary" />
                </div>

                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Sort By</label>
                    <select name="sortOrder" class="form-select border-light-subtle shadow-sm rounded-pill">
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Newest</option>
                        <option value="salary_desc" selected="@(ViewBag.CurrentSort == "salary_desc")">Highest Salary</option>
                        <option value="salary_asc" selected="@(ViewBag.CurrentSort == "salary_asc")">Lowest Salary</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill flex-grow-1 shadow-sm">
                        <i class="bi bi-filter"></i> Apply
                    </button>
                    <a asp-action="List" asp-route-category="@ViewBag.CategoryName" class="btn btn-light border rounded-pill shadow-sm">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>

                @if (isStaff)
                {
                    <div class="col-12 mt-3">
                        <div class="form-check form-switch p-3 border rounded-pill bg-light d-inline-flex align-items-center" style="padding-left: 3.5em !important;">
                            <input class="form-check-input me-2" type="checkbox" name="showInactive" value="true" id="showInactive"
                                   @(showInactive ? "checked" : "") onchange="this.form.submit()" style="cursor: pointer; transform: scale(1.2);">
                            <label class="form-check-label fw-bold text-dark mb-0" for="showInactive" style="cursor: pointer;">
                                <i class="bi bi-eye-fill text-primary me-1"></i> Show Hidden & Expired (Staff Mode)
                            </label>
                            <input type="hidden" name="showInactive" value="false" />
                        </div>
                    </div>
                }
            </form>
        </div>
    </div>

    <div class="row g-4">
        @if (!visibleOffers.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light rounded-4 p-5 border border-dashed">
                    <i class="bi bi-search text-muted display-1 mb-4 d-block"></i>
                    <h3 class="fw-bold">No offers found</h3>
                    <p class="text-muted">Try adjusting your filters.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var item in visibleOffers)
            {
                bool isExpired = item.ExpirationDate.HasValue && item.ExpirationDate < DateTime.Now;
                bool isAuthorBanned = item.User.LockoutEnd.HasValue && item.User.LockoutEnd.Value > DateTimeOffset.UtcNow;
                bool isInactive = !item.IsVisible || isAuthorBanned || isExpired;

                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm job-card rounded-4 @(isInactive ? "opacity-75 border-dashed-danger" : "")">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex flex-column gap-1">
                                    <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">
                                        <i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrEmpty(item.Location) ? "Remote" : item.Location)
                                    </span>
                                    @if (isStaff && isInactive)
                                    {
                                        <div class="d-flex gap-1 flex-wrap mt-1">
                                            @if (!item.IsVisible)
                                            {
                                                <span class="badge bg-danger">HIDDEN</span>
                                            }
                                            @if (isExpired)
                                            {
                                                <span class="badge bg-warning text-dark">EXPIRED</span>
                                            }
                                            @if (isAuthorBanned)
                                            {
                                                <span class="badge bg-dark text-white">USER BANNED</span>
                                            }
                                        </div>
                                    }
                                </div>
                                <small class="text-muted fw-bold">
                                    <i class="bi bi-clock me-1"></i>@(item.JobType ?? "Full-time")
                                </small>
                            </div>

                            <h4 class="card-title fw-bold mb-1">@item.Title</h4>
                            <p class="text-primary fw-semibold mb-3">
                                <i class="bi bi-building me-1"></i>@item.Company
                            </p>

                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <small class="text-muted border rounded-pill px-2 py-1 bg-light" style="font-size: 0.75rem;">
                                    <i class="bi bi-calendar-plus me-1"></i>Added: @item.CreatedAt.ToString("dd.MM.yyyy")
                                </small>

                                @if (item.ExpirationDate.HasValue)
                                {
                                    <small class="border rounded-pill px-2 py-1 @(isExpired ? "bg-soft-danger text-danger border-danger" : "bg-light text-muted")" style="font-size: 0.75rem;">
                                        <i class="bi bi-calendar-x me-1"></i>
                                        @(isExpired ? "Ended: " : "Ends: ") @item.ExpirationDate.Value.ToString("dd.MM.yyyy")
                                    </small>
                                }
                            </div>

                            <div class="mb-4">
                                <p class="text-muted small line-clamp-3">@Html.Raw(item.Description)</p>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <div class="salary-box">
                                    <span class="text-success fw-bold">@item.MinimumSalary PLN</span>
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary rounded-pill px-4">Details</a>
                            </div>

                            @if (isStaff)
                            {
                                <div class="mt-3 p-2 bg-light rounded-3 border-top">
                                    <div class="d-flex gap-2">
                                        @if (item.IsVisible)
                                        {
                                            <button onclick="openVisibilityModal('@item.Id', 'hide', '@item.Title')" class="btn btn-sm btn-outline-warning flex-grow-1 rounded-pill">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button onclick="openVisibilityModal('@item.Id', 'show', '@item.Title')" class="btn btn-sm btn-success text-white flex-grow-1 rounded-pill">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        }
                                        <button onclick="openFlagModal('@item.Id', '@item.Title')" class="btn btn-sm btn-outline-danger flex-grow-1 rounded-pill">
                                            <i class="bi bi-flag"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal fade" id="visibilityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="visibilityForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Change Visibility</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="visibilityModalText"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" id="visibilityConfirmBtn">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="flagModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="flagForm" method="post" asp-action="ReportUser" asp-controller="Offer">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="flagOfferId" />
                <div class="modal-header text-danger">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Report Offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Report offer: <strong id="flagOfferTitle"></strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Report & Hide</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openVisibilityModal(id, action, title) {
        const modal = new bootstrap.Modal(document.getElementById('visibilityModal'));
        const form = document.getElementById('visibilityForm');
        const text = document.getElementById('visibilityModalText');
        const btn = document.getElementById('visibilityConfirmBtn');

        if (action === 'hide') {
            text.innerHTML = `Are you sure you want to <strong>HIDE</strong>: <strong>${title}</strong>?`;
            form.action = `/Offer/HideOffer/${id}`;
            btn.className = 'btn btn-warning';
        } else {
            text.innerHTML = `Are you sure you want to <strong>SHOW</strong>: <strong>${title}</strong>?`;
            form.action = `/Offer/ShowOffer/${id}`;
            btn.className = 'btn btn-success';
        }
        modal.show();
    }

    function openFlagModal(id, title) {
        const modal = new bootstrap.Modal(document.getElementById('flagModal'));
        document.getElementById('flagOfferId').value = id;
        document.getElementById('flagOfferTitle').innerText = title;
        modal.show();
    }
</script>