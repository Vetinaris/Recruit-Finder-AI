@model IEnumerable<Recruit_Finder_AI.Models.JobOffer>
@{
    ViewData["Title"] = ViewBag.CategoryName + " Jobs";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3">
        <div class="text-center text-md-start">
            <h1 class="fw-bold display-6 mb-1">Opportunities in <span class="text-primary">@ViewBag.CategoryName</span></h1>
            <p class="text-muted fs-5 mb-0">Discover your next career move with AI match analysis.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 shadow-sm transition-hover">
            <i class="bi bi-grid-3x3-gap me-2"></i>Browse Categories
        </a>
    </div>

    <div class="row g-4">
        @{
            var visibleOffers = Model.Where(item =>
            User.IsInRole("MODERATOR") ||
            (item.IsVisible && (!item.User.LockoutEnd.HasValue || item.User.LockoutEnd.Value <= DateTimeOffset.UtcNow))
            );
        }

        <div class="card border-0 shadow-sm rounded-4 mb-5 bg-light">
            <div class="card-body p-4">
                <form method="get" asp-action="List" class="row g-3 align-items-end">
                    <input type="hidden" name="category" value="@ViewBag.CategoryName" />
            
                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Job Type</label>
                        <select name="jobType" class="form-select border-0 shadow-sm rounded-pill">
                            <option value="">All Types</option>
                            <option value="Full-time" selected="@(ViewBag.CurrentJobType == "Full-time")">Full-time</option>
                            <option value="Part-time" selected="@(ViewBag.CurrentJobType == "Part-time")">Part-time</option>
                            <option value="Contract" selected="@(ViewBag.CurrentJobType == "Contract")">Contract</option>
                            <option value="Freelance" selected="@(ViewBag.CurrentJobType == "Freelance")">Freelance</option>
                            <option value="B2B" selected="@(ViewBag.CurrentJobType == "B2B")">B2B</option>
                            <option value="Internship" selected="@(ViewBag.CurrentJobType == "Internship")">Internship</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Salary Type</label>
                        <select name="salaryType" class="form-select border-0 shadow-sm rounded-pill">
                            <option value="">Any Salary Type</option>
                            <option value="none" selected="@(ViewBag.CurrentSalaryType == "none")">Undisclosed</option>
                            <option value="negotiable" selected="@(ViewBag.CurrentSalaryType == "negotiable")">Negotiable</option>
                            <option value="fixed" selected="@(ViewBag.CurrentSalaryType == "fixed")">Fixed Price</option>
                            <option value="range" selected="@(ViewBag.CurrentSalaryType == "range")">Salary Range</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label small fw-bold text-muted text-uppercase">Min. PLN</label>
                        <input type="number" name="minSalary" class="form-control border-0 shadow-sm rounded-pill" 
                               placeholder="e.g. 5000" value="@ViewBag.CurrentMinSalary" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label small fw-bold text-muted text-uppercase">Sort By</label>
                        <select name="sortOrder" class="form-select border-0 shadow-sm rounded-pill">
                            <option value="newest" selected="@(ViewBag.CurrentSort == "newest")">Newest</option>
                            <option value="salary_desc" selected="@(ViewBag.CurrentSort == "salary_desc")">Highest Salary</option>
                            <option value="salary_asc" selected="@(ViewBag.CurrentSort == "salary_asc")">Lowest Salary</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill flex-grow-1 shadow-sm">
                            <i class="bi bi-filter me-1"></i> Apply
                        </button>
                        <a asp-action="List" asp-route-category="@ViewBag.CategoryName" class="btn btn-white border rounded-pill shadow-sm">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        @if (!visibleOffers.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light rounded-4 p-5 border shadow-sm">
                    <i class="bi bi-search text-muted display-1 mb-4 d-block"></i>
                    <h3 class="fw-bold">No offers found yet</h3>
                    <p class="text-muted">Check back later or try a different category.</p>
                </div>
            </div>
        }

        @foreach (var item in visibleOffers)
        {
            bool isAuthorBanned = item.User.LockoutEnd.HasValue && item.User.LockoutEnd.Value > DateTimeOffset.UtcNow;
            bool isInactive = !item.IsVisible || isAuthorBanned;

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm job-card rounded-4 @(isInactive ? "opacity-75 border-dashed" : "")">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">
                                <i class="bi bi-geo-alt me-1"></i>@(string.IsNullOrEmpty(item.Location) ? "Remote" : item.Location)
                            </span>
                            <small class="text-muted fw-bold">@(string.IsNullOrEmpty(item.JobType) ? "Full-time" : item.JobType)</small>
                        </div>

                        <h4 class="card-title fw-bold mb-1 text-dark">@item.Title</h4>
                        <p class="text-primary fw-bold mb-3">@item.Company</p>

                        <div class="mb-4">
                            <p class="text-muted small mb-0 line-clamp-3">
                                @(item.Description?.Length > 120 ? item.Description.Substring(0, 120) + "..." : item.Description)
                            </p>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                            <div class="text-success fw-bold">
                                @if (item.SalaryType == "fixed")
                                {
                                    <span>PLN @item.MinimumSalary?.ToString("N0")</span>
                                }
                                else if (item.SalaryType == "range")
                                {
                                    <span>PLN @item.MinimumSalary?.ToString("N0") - @item.MaximumSalary?.ToString("N0")</span>
                                }
                                else if (item.SalaryType == "negotiable")
                                {
                                    <span class="text-muted small text-uppercase">Negotiable</span>
                                }
                                else
                                {
                                    <span class="text-muted small text-uppercase">Undisclosed</span>
                                }
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary rounded-pill px-4 shadow-sm @(isAuthorBanned && !User.IsInRole("MODERATOR") ? "disabled" : "")">
                                View Details
                            </a>
                        </div>

                        @if (User.IsInRole("MODERATOR"))
                        {
                            <div class="mt-3 p-3 bg-light rounded-4 border @(isInactive ? "border-danger bg-soft-danger" : "")">
                                <div class="small fw-bold text-uppercase text-muted mb-2 text-center">Moderator Control Panel</div>

                                <div class="d-flex gap-2">
                                    @if (item.IsVisible)
                                    {
                                        <button type="button" class="btn btn-white btn-sm flex-grow-1 rounded-pill border shadow-sm"
                                                onclick="openVisibilityModal('@item.Id', 'hide', '@item.Title')">
                                            <i class="bi bi-eye-slash text-warning"></i> Hide
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-success btn-sm flex-grow-1 rounded-pill text-white shadow-sm"
                                                onclick="openVisibilityModal('@item.Id', 'show', '@item.Title')">
                                            <i class="bi bi-eye"></i> Show
                                        </button>
                                    }

                                    <button type="button" class="btn btn-outline-danger btn-sm flex-grow-1 rounded-pill"
                                            onclick="openFlagModal('@item.Id', '@item.Title')">
                                        <i class="bi bi-flag"></i> Flag
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="visibilityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div id="visibilityIcon" class="icon-shape rounded-circle mb-3 mx-auto" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; font-size: 2.2rem;">
                </div>
                <h4 class="fw-bold" id="visibilityModalTitle">Change Visibility</h4>
                <p class="text-muted mb-4">Are you sure you want to <span id="visibilityActionText" class="fw-bold"></span> the offer: <strong id="visibilityOfferName" class="text-dark"></strong>?</p>
                
                <form id="visibilityForm" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-grid gap-2">
                        <button type="submit" id="visibilityConfirmBtn" class="btn btn-lg rounded-pill fw-bold shadow-sm">Confirm Change</button>
                        <button type="button" class="btn btn-light btn-lg rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="flagModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="icon-shape bg-soft-danger text-danger rounded-circle mb-3 mx-auto" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; font-size: 2.2rem;">
                    <i class="bi bi-flag-fill"></i>
                </div>
                <h4 class="fw-bold">Flag Offer & Author?</h4>
                <p class="text-muted mb-4">This will hide the offer "<strong id="flagOfferName"></strong>" and notify Administrators for serious rule violations.</p>
                
                <form id="flagForm" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold shadow-sm">Confirm Flag</button>
                        <button type="button" class="btn btn-light btn-lg rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openVisibilityModal(id, action, title) {
            const form = document.getElementById('visibilityForm');
            const titleElem = document.getElementById('visibilityModalTitle');
            const actionText = document.getElementById('visibilityActionText');
            const offerName = document.getElementById('visibilityOfferName');
            const confirmBtn = document.getElementById('visibilityConfirmBtn');
            const iconContainer = document.getElementById('visibilityIcon');

            offerName.innerText = title;
            
            if (action === 'hide') {
                form.action = '/Offer/HideOffer/' + id;
                titleElem.innerText = 'Hide Offer?';
                actionText.innerText = 'HIDE';
                confirmBtn.className = 'btn btn-warning btn-lg rounded-pill fw-bold shadow-sm';
                iconContainer.className = 'icon-shape bg-soft-warning text-warning rounded-circle mb-3 mx-auto';
                iconContainer.innerHTML = '<i class="bi bi-eye-slash-fill"></i>';
            } else {
                form.action = '/Offer/ShowOffer/' + id;
                titleElem.innerText = 'Show Offer?';
                actionText.innerText = 'SHOW';
                confirmBtn.className = 'btn btn-success btn-lg rounded-pill fw-bold shadow-sm';
                iconContainer.className = 'icon-shape bg-soft-success text-success rounded-circle mb-3 mx-auto';
                iconContainer.innerHTML = '<i class="bi bi-eye-fill"></i>';
            }

            new bootstrap.Modal(document.getElementById('visibilityModal')).show();
        }

        function openFlagModal(id, title) {
            document.getElementById('flagOfferName').innerText = title;
            document.getElementById('flagForm').action = '/Offer/ReportUser/' + id;
            new bootstrap.Modal(document.getElementById('flagModal')).show();
        }
    </script>
}

<style>
    .job-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border: 1px solid #f0f0f0 !important;
    }

        .job-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(67, 97, 238, 0.12) !important;
            border-color: #4361ee !important;
        }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    .bg-soft-danger {
        background-color: rgba(220, 53, 69, 0.05);
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .btn-white {
        background: white;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .icon-shape { display: flex; align-items: center; justify-content: center; }
</style>