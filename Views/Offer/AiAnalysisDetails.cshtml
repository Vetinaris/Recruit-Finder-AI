@model Recruit_Finder_AI.Models.JobOffer
@{
    ViewData["Title"] = "AI Analysis Details";
    var aiReports = ViewBag.AiReports as List<Recruit_Finder_AI.Models.AiApplicationReport> ?? new List<Recruit_Finder_AI.Models.AiApplicationReport>();
    var offerTitle = Model.Title ?? "Job Offer Results";

    List<RankingItem> aiRanking = null;

    if (Model.Applications != null && Model.Applications.Any())
    {
        aiRanking = (from app in Model.Applications
                     join report in aiReports on app.Id equals report.JobApplicationId
                     select new RankingItem
                     {
                         Application = app,
                         Report = report
                     })
                     .OrderByDescending(x => x.Report.Score)
                     .Take(10)
                     .ToList();
    }
    else
    {
        aiRanking = new List<RankingItem>();
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/offer.css" />
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <a asp-action="ClosedListings" class="btn btn-link text-muted p-0 me-3">
                <i class="bi bi-arrow-left fs-4"></i>
            </a>
            <div>
                <h1 class="fw-bold h3 mb-0">AI Verification Details</h1>
                <p class="text-muted mb-0">Analysis for recruitment at: <strong>@Model.Company</strong></p>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            @if (aiReports.Any())
            {
                <a asp-action="ExportAiResultsToCsv" asp-route-id="@Model.Id" class="btn btn-light btn-sm rounded-pill fw-bold px-3 border shadow-sm hover-lift text-success">
                    <i class="bi bi-file-earmark-spreadsheet-fill me-1"></i> Export to CSV
                </a>
            }
            <div class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 fw-bold">
                Top 10 Ranked Candidates
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 p-4 bg-white border-start border-purple border-4" style="border-left-width: 5px !important;">
        <div class="d-flex align-items-center mb-2">
            <div class="avatar-circle-numbered bg-soft-info text-info me-3 fs-4">
                <i class="bi bi-robot"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-0" style="color: #6f42c1;">Main Analysis Status: @Model.AiAnalysisStatus</h5>
                <small class="text-muted">Global summary generated by Gemma 3:4b</small>
            </div>
        </div>
        <div class="message-bubble-card mt-3">
            <div class="message-content" style="white-space: pre-line;">@Model.AiAnalysisComment</div>
        </div>
    </div>

    <div class="accordion custom-accordion mb-4" id="offerDetailsAccordion">
        <div class="accordion-item border-0 shadow-sm rounded-4 overflow-hidden">
            <h2 class="accordion-header" id="headingOffer">
                <button class="accordion-button collapsed fw-bold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOffer" aria-expanded="false" aria-controls="collapseOffer">
                    <i class="bi bi-briefcase-fill text-primary me-2"></i> View Job Offer Details & Requirements (@Model.Company)
                </button>
            </h2>
            <div id="collapseOffer" class="accordion-collapse collapse" aria-labelledby="headingOffer" data-bs-parent="#offerDetailsAccordion">
                <div class="accordion-body bg-white p-0">
                    <div class="row g-0">
                        <div class="col-lg-8 p-4 p-md-5 border-end bg-white">
                            <div class="mb-4">
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">@Model.Category</span>
                                    @if (!string.IsNullOrEmpty(Model.Subcategory))
                                    {
                                        <span class="badge bg-light text-secondary border rounded-pill px-3 py-2">
                                            <i class="bi bi-tag-fill me-1 small"></i>@Model.Subcategory
                                        </span>
                                    }
                                </div>

                                <h2 class="fw-bold text-dark mb-3">@Model.Title</h2>

                                <div class="row g-3">
                                    <div class="col-sm-6 col-md-4">
                                        <div class="d-flex align-items-center text-muted">
                                            <i class="bi bi-building me-2 text-primary"></i>
                                            <span class="fw-semibold small">@Model.Company</span>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 col-md-4">
                                        <div class="d-flex align-items-center text-muted">
                                            <i class="bi bi-geo-alt me-2 text-primary"></i>
                                            <span class="small">@(string.IsNullOrEmpty(Model.Location) ? "Remote" : Model.Location)</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">
                                <i class="bi bi-card-text me-2 text-primary"></i>Job Description
                            </h5>
                            <div class="text-secondary small mb-5" style="text-indent: 20px; text-align: justify; line-height: 1.5;">
                                @Model.Description
                            </div>

                            <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">
                                <i class="bi bi-list-check me-2 text-primary"></i>Key Requirements
                            </h5>
                            <div class="requirements-section">
                                @if (!string.IsNullOrEmpty(Model.Requirements))
                                {
                                    <div class="small" style="white-space: normal !important;">
                                        @foreach (var req in Model.Requirements.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            if (!string.IsNullOrWhiteSpace(req))
                                            {
                                                <div class="d-flex align-items-start mb-3">
                                                    <i class="bi bi-check2-circle text-primary me-2 mt-1" style="font-size: 0.9rem; line-height: 1; flex-shrink: 0;"></i>
                                                    <span style="line-height: 1.4; text-align: justify; width: 100%;">@req.Trim()</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted fst-italic small">No specific requirements listed.</p>
                                }
                            </div>
                        </div>

                        <div class="col-lg-4 bg-light p-4">
                            <div class="sticky-top" style="top: 1rem; z-index: 1;">
                                <h5 class="fw-bold mb-4 text-dark">Summary</h5>
                                
                                <div class="bg-white rounded-4 p-3 shadow-sm mb-4 border-start border-success border-4">
                                    <label class="text-muted small text-uppercase fw-bold d-block mb-1" style="font-size: 0.8rem;">Salary Range</label>
                                    <div class="salary-container">
                                        <span class="text-success fw-bold fs-5 text-nowrap d-inline-block" style="letter-spacing: -0.4px;">
                                            @if (Model.SalaryType == "fixed")
                                            {
                                                @:EUR @Model.MinimumSalary?.ToString("N0")
                                            }
                                            else if (Model.SalaryType == "range")
                                            {
                                                @:EUR @Model.MinimumSalary?.ToString("N0") - @Model.MaximumSalary?.ToString("N0")
                                            }
                                            else if (Model.SalaryType?.ToLower() == "negotiable")
                                            {
                                                @:Negotiable
                                            }
                                            else
                                            {
                                                @:Not Disclosed
                                            }
                                        </span>
                                    </div>
                                    <small class="text-muted d-block mt-1" style="font-size: 0.8rem;">Gross / Month</small>
                                </div>

                                <div class="bg-white rounded-4 p-3 shadow-sm mb-3">
                                    <div class="d-flex align-items-center mb-3">
                                        <i class="bi bi-briefcase me-3 fs-5 text-primary"></i>
                                        <div>
                                            <small class="text-muted d-block" style="font-size: 0.8rem; font-weight: 700;">Job Type</small>
                                            <span class="fw-semibold text-dark small">@Model.JobType</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-translate me-3 fs-5 text-primary"></i>
                                        <div>
                                            <small class="text-muted d-block" style="font-size: 0.8rem; font-weight: 700;">Languages</small>
                                            <div class="d-flex flex-wrap gap-1 mt-1">
                                                @if (!string.IsNullOrEmpty(Model.RequiredLanguages))
                                                {
                                                    @foreach (var lang in Model.RequiredLanguages.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                                                    {
                                                        <span class="badge bg-soft-secondary text-secondary rounded-pill border px-2 py-1 small">
                                                            @lang.Trim()
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">-</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold text-dark mb-3">Top AI Candidate Ranking</h4>

    @if (aiRanking != null && aiRanking.Any())
    {
        <div class="row row-cols-1 row-cols-lg-2 g-4 mb-4">
            @foreach (var candidate in aiRanking)
            {
                var cv = candidate.Application.Cv;
                var app = candidate.Application;
                string candidateName = cv != null ? $"{cv.Surname} {cv.Name}" : "Hidden Name";

                var prosList = candidate.Report.Pros?.Split(new[] { '\n' }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                var consList = candidate.Report.Cons?.Split(new[] { '\n' }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();

                string userPhoto = null;
                if (app.Cv?.User?.ProfilePicture != null && app.Cv.User.ProfilePicture.Length > 0)
                {
                    var base64 = Convert.ToBase64String(app.Cv.User.ProfilePicture);
                    userPhoto = $"data:image/jpeg;base64,{base64}";
                }

                <div class="col">
                    <div class="card h-100 border-0 custom-main-shadow rounded-4 bg-white p-4 border-start border-4" style="border-left-color: @(candidate.Report.Score >= 80 ? "#ffc107" : "#6f42c1") !important;">
                        
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    @if (!string.IsNullOrEmpty(userPhoto))
                                    {
                                        <img src="@userPhoto" alt="Avatar" class="avatar-img-circle shadow-sm" />
                                    }
                                    else
                                    {
                                        <div class="avatar-placeholder bg-soft-primary text-primary">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                    }
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0 text-dark">@candidateName</h5>
                                    <small class="text-muted d-block"><i class="bi bi-calendar-event me-1"></i>Applied: @app.AppliedAt.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                            
                            <span class="badge fs-6 rounded-pill px-3 py-2 @(candidate.Report.Score >= 80 ? "bg-soft-success text-success" : candidate.Report.Score >= 50 ? "bg-soft-info text-info" : "bg-soft-secondary text-secondary")" style="font-weight: 700;">
                                <i class="bi bi-patch-check-fill me-1"></i> @candidate.Report.Score% Match
                            </span>
                        </div>

                        <div class="p-3 bg-light rounded-3 mb-3 border-0 position-relative">
                            <p class="text-secondary small mb-0 fst-italic text-justify" style="line-height: 1.5;">
                                <i class="bi bi-quote fs-5 text-muted opacity-50 me-1"></i>@candidate.Report.Description
                            </p>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <span class="fw-bold text-success small d-block mb-2"><i class="bi bi-plus-circle-fill me-1"></i> Pros:</span>
                                <ul class="ps-3 mb-0 small text-secondary" style="list-style-type: square;">
                                    @foreach (var pro in prosList)
                                    {
                                        <li class="mb-1 text-justify">@pro.TrimStart('-', ' ')</li>
                                    }
                                    @if (!prosList.Any())
                                    {
                                        <li class="text-muted fst-italic">None listed</li>
                                    }
                                </ul>
                            </div>
                            <div class="col-6">
                                <span class="fw-bold text-danger small d-block mb-2"><i class="bi bi-dash-circle-fill me-1"></i> Cons:</span>
                                <ul class="ps-3 mb-0 small text-secondary" style="list-style-type: square;">
                                    @foreach (var con in consList)
                                    {
                                        <li class="mb-1 text-justify">@con.TrimStart('-', ' ')</li>
                                    }
                                    @if (!consList.Any())
                                    {
                                        <li class="text-muted fst-italic">None listed</li>
                                    }
                                </ul>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top bg-light mx-n4 mb-n4 px-4 py-3 rounded-bottom-4">
                            <span class="small text-muted fw-semibold">Application Actions:</span>
                            
                            <div class="btn-group glass-actions shadow-xs">
                                <a asp-controller="Offer" asp-action="CvView" asp-route-id="@app.CvId" class="btn action-btn text-primary" title="View Full CV">
                                    <i class="bi bi-file-earmark-person-fill"></i>
                                </a>
                                <a asp-controller="Offer" asp-action="DownloadCv" asp-route-id="@app.CvId" download class="btn action-btn text-success" title="Download PDF">
                                    <i class="bi bi-download"></i>
                                </a>
                                <button type="button" class="btn action-btn text-success" data-bs-toggle="modal" data-bs-target="#selectCandidateModal-@app.Id" title="Select Candidate and Notify">
                                    <i class="bi bi-check-circle-fill"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @foreach (var candidate in aiRanking)
        {
            var cv = candidate.Application.Cv;
            var app = candidate.Application;
            string candidateName = cv != null ? $"{cv.Surname} {cv.Name}" : "Hidden Name";
            
            <div class="modal fade" id="selectCandidateModal-@app.Id" tabindex="-1" aria-labelledby="selectCandidateModalLabel-@app.Id" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 custom-main-shadow rounded-4">
                        <div class="modal-header border-0 pb-0 d-flex justify-content-end">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form asp-action="NotifySelectedCandidate" asp-controller="Offer" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="applicationId" value="@app.Id" />
                            <input type="hidden" name="jobId" value="@Model.Id" />
                            <input type="hidden" name="jobTitle" value="@offerTitle" />
                
                            <input type="hidden" name="returnView" value="AiAnalysisDetails" />

                            <div class="modal-body text-center px-4 pb-4">
                                <div class="icon-box-circle mb-4 bg-soft-success text-success mx-auto d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; border-radius: 50%;">
                                    <i class="bi bi-check-circle-fill fs-2"></i>
                                </div>
                                <h3 class="fw-bold text-dark mb-2">Confirm Selection</h3>
                                <p class="text-muted mb-0">
                                    Are you sure you want to select <br>
                                    <span class="fw-bold text-success">@candidateName</span> <br>
                                    for the position: <strong class="text-dark">@offerTitle</strong>?
                                </p>

                                <div class="alert alert-info mt-4 border-0 rounded-3 small text-start d-flex align-items-start gap-2 bg-soft-info text-info">
                                    <i class="bi bi-info-circle-fill mt-0.5 flex-shrink-0"></i>
                                    <span>An automated notification will be sent to the candidate informing them that they have been selected for the recruitment process for <strong>@offerTitle</strong> and asking them to check their e-mail inbox.</span>
                                </div>
                            </div>

                            <div class="modal-footer border-0 justify-content-center gap-2 pb-5">
                                <button type="button" class="btn btn-light rounded-pill px-4 fw-semibold border hover-shift" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm hover-lift text-white">
                                    Accept & Send
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info border-0 shadow-sm p-4 rounded-4 text-center">
            <i class="bi bi-info-circle-fill me-2 fs-4 d-block mb-2 text-info"></i>
            No active AI reports are currently linked or saved for this offer. Trigger the AI analysis first.
        </div>
    }

    <div class="mt-4">
        <a asp-action="ViewResults" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill px-4 fw-medium hover-shift">
            <i class="bi bi-arrow-left me-1"></i> Back to Applications List
        </a>
    </div>
</div>

@functions {
    public class RankingItem
    {
        public Recruit_Finder_AI.Models.JobApplication Application { get; set; }
        public Recruit_Finder_AI.Models.AiApplicationReport Report { get; set; }
    }
}