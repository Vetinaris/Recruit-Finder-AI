@model Recruit_Finder_AI.Models.JobOffer

<div class="container py-5">
    <div class="card border-0 shadow-lg rounded-4">
        <div class="card-header bg-success text-white p-4 rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-robot me-2"></i> AI Verification Report</h2>
        </div>
        <div class="card-body p-4">
            <h4 class="fw-bold">@Model.Title</h4>
            <p class="text-muted">Analysis for: <strong>@Model.Company</strong></p>

            <hr />

            <div class="mt-4">
                <h5 class="fw-bold text-success">
                    <i class="bi bi-shield-check me-2"></i> Analysis Result: @Model.AiAnalysisStatus
                </h5>
                <div class="p-4 bg-light rounded-3 border">
                    <p class="mb-0" style="white-space: pre-line;">
                        @Model.AiAnalysisComment
                    </p>
                </div>
            </div>

            <div class="mt-4">
                <a asp-action="ClosedListings" class="btn btn-outline-secondary rounded-pill">
                    Back to History
                </a>
            </div>
        </div>
    </div>
</div>