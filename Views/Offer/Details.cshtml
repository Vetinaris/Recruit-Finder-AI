@model Recruit_Finder_AI.Models.JobOffer
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title + " | Recruit Finder AI";
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isActualOwner = User.Identity.IsAuthenticated && Model.RecruiterId == userId;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-action="List" asp-route-category="@Model.Category" class="btn btn-link text-decoration-none p-0 text-secondary hover-shift-left">
                    <i class="bi bi-arrow-left me-2"></i>Back to @Model.Category Offers
                </a>

                @if (isActualOwner)
                {
                    <div class="btn-group shadow-sm rounded-pill overflow-hidden border">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-white btn-sm px-4 fw-bold">
                            <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Offer
                        </a>
                        <a asp-action="MyListings" class="btn btn-white btn-sm px-4 fw-bold border-start">
                            <i class="bi bi-gear-fill me-2 text-secondary"></i>Manage
                        </a>
                    </div>
                }
            </div>

            @if ((User.IsInRole("ADMIN") || User.IsInRole("MODERATOR")) && (!Model.IsVisible || (Model.User?.LockoutEnd > DateTimeOffset.UtcNow)))
            {
                <div class="alert bg-soft-warning border-warning rounded-4 mb-4 shadow-sm">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-shield-exclamation fs-3 me-3 text-warning"></i>
                        <div>
                            <strong class="text-dark">Staff Mode:</strong> This offer is <strong>hidden</strong> or the author is <strong>banned</strong>.
                            It is currently invisible to regular candidates.
                        </div>
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-body p-0">
                    <div class="row g-0">

                        <div class="col-lg-8 p-4 p-md-5 border-end bg-white">
                            <div class="mb-5">
                                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 mb-3">@Model.Category</span>
                                <h1 class="fw-bold text-dark display-5 mb-3">@Model.Title</h1>

                                <div class="row g-3">
                                    <div class="col-sm-6 col-md-3">
                                        <div class="d-flex align-items-center text-muted">
                                            <div class="icon-box bg-light rounded-3 me-2">
                                                <i class="bi bi-building"></i>
                                            </div>
                                            <span class="fw-semibold">@Model.Company</span>
                                        </div>
                                    </div>

                                    <div class="col-sm-6 col-md-3">
                                        <div class="d-flex align-items-center text-muted">
                                            <div class="icon-box bg-light rounded-3 me-2">
                                                <i class="bi bi-geo-alt"></i>
                                            </div>
                                            <span>@(string.IsNullOrEmpty(Model.Location) ? "Remote" : Model.Location)</span>
                                        </div>
                                    </div>

                                    <div class="col-sm-6 col-md-3">
                                        <div class="d-flex align-items-center text-muted">
                                            <div class="icon-box bg-light rounded-3 me-2">
                                                <i class="bi bi-calendar-check"></i>
                                            </div>
                                            <div>
                                                <small class="d-block text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Posted</small>
                                                <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                                            </div>
                                        </div>
                                    </div>

                                    @if (Model.ExpirationDate.HasValue)
                                    {
                                        <div class="col-sm-6 col-md-3">
                                            <div class="d-flex align-items-center text-muted">
                                                <div class="icon-box bg-light rounded-3 me-2">
                                                    <i class="bi bi-calendar-x"></i>
                                                </div>
                                                <div>
                                                    <small class="d-block text-uppercase text-danger" style="font-size: 0.65rem; letter-spacing: 0.5px;">Expires</small>
                                                    <span class="@(Model.ExpirationDate < DateTime.Now ? "text-danger fw-bold" : "")">
                                                        @Model.ExpirationDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <h5 class="fw-bold text-dark border-bottom pb-3 mb-4">Job Description</h5>
                            <div class="job-content">
                                @Model.Description
                            </div>
                        </div>

                        <div class="col-lg-4 bg-light p-4 p-md-5">
                            <div class="sticky-top" style="top: 2rem; z-index: 1;">
                                <h5 class="fw-bold mb-4">Summary</h5>

                                <div class="bg-white rounded-4 p-4 shadow-sm mb-4 border-start border-success border-4">
                                    <label class="text-muted small text-uppercase fw-bold d-block mb-1">Salary Range</label>
                                    <span class="text-success fw-bold fs-4">
                                        @if (Model.SalaryType == "fixed")
                                        {
                                            @:PLN @Model.MinimumSalary?.ToString("N0")
                                        }
                                        else if (Model.SalaryType == "range")
                                        {
                                            @:PLN @Model.MinimumSalary?.ToString("N0") - @Model.MaximumSalary?.ToString("N0")
                                        }
                                        else
                                        {
                                            <span class="text-secondary text-capitalize">@Model.SalaryType</span>
                                        }
                                    </span>
                                    <small class="text-muted d-block mt-1">Gross / Month</small>
                                </div>

                                <div class="mb-4">
                                    <div class="d-flex mb-3">
                                        <i class="bi bi-briefcase text-primary me-3 fs-5"></i>
                                        <div>
                                            <small class="text-muted d-block">Contract Type</small>
                                            <span class="fw-bold text-dark">@(string.IsNullOrEmpty(Model.JobType) ? "Full-time" : Model.JobType)</span>
                                        </div>
                                    </div>

                                    <div class="d-flex mb-3">
                                        <i class="bi bi-robot text-primary me-3 fs-5"></i>
                                        <div>
                                            <small class="text-muted d-block">AI Evaluation</small>
                                            <span class="fw-bold text-dark">AI-Matched Candidate Pool</span>
                                        </div>
                                    </div>
                                </div>

                                <hr class="my-4 opacity-50">

                                @if (User.Identity.IsAuthenticated && !User.IsInRole("ADMIN") && !User.IsInRole("MODERATOR"))
                                {
                                    <a href="mailto:careers@@recruitfinder.ai?subject=Application: @Model.Title" class="btn btn-primary btn-lg w-100 rounded-pill shadow mb-3 py-3 fw-bold">
                                        Apply Now <i class="bi bi-send-fill ms-2"></i>
                                    </a>
                                }
                                else if (!User.Identity.IsAuthenticated)
                                {
                                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg w-100 rounded-pill shadow mb-3 py-3 fw-bold">
                                        Login to Apply
                                    </a>
                                }

                                <div class="text-center">
                                    <p class="small text-muted mb-0">Direct application via <span class="fw-bold">Recruit Finder AI</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center px-4">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i> Security Note: Never send money or sensitive personal data like ID numbers directly to recruiters via email.
                </p>
            </div>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8fafd;
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .bg-white {
        background-color: #ffffff;
    }

    .icon-box {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4361ee;
    }

    .job-content {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #3d4451;
        white-space: pre-wrap;
    }

    .hover-shift-left {
        transition: transform 0.2s ease;
    }

        .hover-shift-left:hover {
            transform: translateX(-5px);
            color: #4361ee !important;
        }

    .btn-white {
        background: #fff;
        color: #444;
        transition: all 0.2s ease;
    }

        .btn-white:hover {
            background: #f8f9fa;
            color: #000;
        }

    .card {
        border-radius: 1.25rem !important;
    }
</style>