@model Recruit_Finder_AI.Models.JobOffer

@{
    ViewData["Title"] = "Job Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="badge bg-white text-primary mb-2">@Model.Category</span>
                            <h1 class="h2 mb-1 fw-bold">@Model.Title</h1>
                            <p class="mb-0 opacity-75">
                                <i class="bi bi-building me-1"></i> @Model.Company
                                <span class="mx-2">|</span>
                                <i class="bi bi-geo-alt me-1"></i> @Model.Location
                            </p>
                        </div>
                        <a asp-action="List" asp-route-category="@Model.Category" class="btn btn-sm btn-light text-primary shadow-sm">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="row mb-4">
                        <div class="col-sm-4 mb-3 mb-sm-0">
                            <div class="p-3 bg-light rounded text-center h-100">
                                <i class="bi bi-briefcase text-primary mb-2 d-block fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold">Type</small>
                                <span>Full-Time</span>
                            </div>
                        </div>
                        <div class="col-sm-4 mb-3 mb-sm-0">
                            <div class="p-3 bg-light rounded text-center h-100">
                                <i class="bi bi-calendar-event text-primary mb-2 d-block fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold">Posted</small>
                                <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 bg-light rounded text-center h-100">
                                <i class="bi bi-cash-stack text-primary mb-2 d-block fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold">Salary</small>
                                <span>Negotiable</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">
                        <i class="bi bi-file-text me-2"></i>Job Description
                    </h5>

                    <div class="job-description text-secondary mb-4" style="white-space: pre-wrap; line-height: 1.8; font-size: 1.1rem;">
                        @Model.Description
                    </div>
                </div>

                <div class="card-footer bg-white border-top p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

                        <div class="w-100 w-md-auto text-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a href="mailto:contact@recruitfinder.ai?subject=Application for @Model.Title" class="btn btn-success btn-lg px-5 shadow-sm">
                                    <i class="bi bi-send-fill me-2"></i>Apply for this position
                                </a>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-5 shadow-sm">
                                    Login to Apply
                                </a>
                            }
                        </div>

                        <div class="btn-group shadow-sm">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i> Edit
                            </a>
                            <a asp-action="MyListings" class="btn btn-outline-secondary">
                                <i class="bi bi-list-task me-1"></i> Manage All
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <p class="text-center text-muted mt-4 small">
                Referenced Offer ID: @Model.Id • Please mention Recruit_Finder_AI when applying.
            </p>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 12px;
        overflow: hidden;
    }

    .card-header {
        border-radius: 0 !important;
    }

    .job-description {
        color: #4a4a4a !important;
    }

    .bg-light {
        background-color: #f8f9fa !important;
        border: 1px solid #eee;
    }
</style>