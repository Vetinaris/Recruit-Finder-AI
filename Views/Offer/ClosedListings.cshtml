@using System.Text.Encodings.Web
@model IEnumerable<Recruit_Finder_AI.Models.JobOffer>
@{
    ViewData["Title"] = "Closed Listings";
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="MyListings" class="btn btn-link text-muted p-0 me-3">
            <i class="bi bi-arrow-left fs-4"></i>
        </a>
        <div>
            <h1 class="fw-bold h3 mb-0">Closed & Expired Listings</h1>
            <p class="text-muted mb-0">History of your recruitment processes</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Offer</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Closed On</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Status</th>
                        <th class="py-3 text-center text-uppercase small fw-bold text-muted">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        bool isVerified = item.AiAnalysisStatus == "Verified";
                        <tr id="row-@item.Id" class="@(isVerified ? "bg-success-subtle" : "bg-light-subtle")">
                            <td class="ps-4 py-3">
                                <div class="fw-bold text-dark d-flex align-items-center">
                                    @item.Title
                                    <div id="verified-badge-@item.Id">
                                        @if (isVerified)
                                        {
                                            <span class="badge bg-success ms-2 small" style="font-size: 0.7rem;">
                                                <i class="bi bi-patch-check-fill me-1"></i>AI Verified
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="small text-muted">@item.Category</div>
                            </td>
                            <td>
                                <div class="small text-muted">
                                    <i class="bi bi-calendar-x me-1"></i>
                                    @(item.ExpirationDate?.ToString("dd MMM yyyy") ?? "Manually closed")
                                </div>
                            </td>
                            <td id="status-container-@item.Id">
                                @if (isVerified)
                                {
                                    <span class="badge rounded-pill bg-success px-3 py-2">Analysis Ready</span>
                                }
                                else if (item.AiAnalysisStatus == "Pending")
                                {
                                    <span class="badge rounded-pill bg-warning text-dark px-3 py-2 ai-status-pending" data-offer-id="@item.Id">
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>AI Processing...
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary px-3 py-2 opacity-75">Archived</span>
                                }
                            </td>
                            <td class="text-center pe-4">
                                <div class="btn-group shadow-sm rounded-pill bg-white border p-1">
                                    <a asp-action="ViewResults" asp-route-id="@item.Id" class="btn btn-link btn-sm text-info p-2" title="View Applications">
                                        <i class="bi bi-person-lines-fill fs-5"></i>
                                    </a>

                                    <div class="vr my-2 text-muted opacity-25"></div>

                                    <div id="ai-button-container-@item.Id" class="d-flex align-items-center">
                                        @if (item.AiAnalysisStatus == "Verified" || item.AiAnalysisStatus == "ManualReview")
                                        {
                                            <a asp-action="AiAnalysisDetails" asp-route-id="@item.Id" class="btn btn-link btn-sm p-2 text-success" title="View AI Analysis">
                                                <i class="bi bi-robot fs-5"></i>
                                                <i class="bi bi-check-circle-fill" style="font-size: 0.6rem; vertical-align: top; margin-left: -8px;"></i>
                                            </a>
                                        }
                                        else if (item.AiAnalysisStatus == "Pending")
                                        {
                                            <button type="button" class="btn btn-link btn-sm p-2 text-warning" disabled>
                                                <i class="bi bi-robot fs-5 opacity-50"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-link btn-sm p-2" style="color: #6f42c1 !important;"
                                                    onclick="openAiModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Request AI Analysis">
                                                <i class="bi bi-robot fs-5"></i>
                                            </button>
                                        }
                                    </div>

                                    <div class="vr my-2 text-muted opacity-25"></div>

                                    <button type="button" class="btn btn-link btn-sm text-success p-2"
                                            onclick="openReopenModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Reactivate Offer">
                                        <i class="bi bi-arrow-clockwise fs-5"></i>
                                    </button>

                                    <div class="vr my-2 text-muted opacity-25"></div>

                                    <button type="button" class="btn btn-link btn-sm text-danger p-2"
                                            onclick="openDeleteModal('@item.Id', '@(JavaScriptEncoder.Default.Encode(item.Title))')" title="Delete Offer Permanently">
                                        <i class="bi bi-trash3-fill fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="aiVerificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold"><i class="bi bi-robot me-2"></i>AI Analysis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="aiVerificationForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p>Are you sure you want to request an AI analysis for:</p>
                    <h6 id="aiOfferTitle" class="fw-bold text-primary"></h6> <p class="small text-muted mb-0 mt-3">
                        <i class="bi bi-info-circle me-1"></i>
                        The process may take up to a minute.
                    </p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" style="background-color: #6f42c1; border: none;">
                        Confirm & Start
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="modal fade" id="reopenOfferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold"><i class="bi bi-arrow-clockwise me-2"></i>Reactivate Offer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="reopenOfferForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p>You are about to move this offer back to the active list:</p>
                    <h6 id="reopenOfferTitle" class="fw-bold text-success"></h6>
                    <p class="small text-muted mb-0 mt-3">
                        <i class="bi bi-info-circle me-1"></i>
                        The offer will be visible to candidates again for 30 days.
                    </p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        Confirm & Reactivate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteOfferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-danger text-white rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Permanent Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="deleteOfferForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body py-4">
                    <p>Are you sure you want to <strong>permanently delete</strong> this offer?</p>
                    <h6 id="deleteOfferTitle" class="fw-bold text-danger"></h6>
                    <div class="alert alert-warning small mt-3 border-0">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        This action cannot be undone. All related applications will also be deleted.
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        Delete Forever
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function openAiModal(offerId, offerTitle) {
            document.getElementById('aiOfferTitle').innerText = offerTitle;
            const form = document.getElementById('aiVerificationForm');
            form.action = '/Offer/VerifyOffer/' + offerId;
            new bootstrap.Modal(document.getElementById('aiVerificationModal')).show();
        }

        function openReopenModal(offerId, offerTitle) {
            document.getElementById('reopenOfferTitle').innerText = offerTitle;
            const form = document.getElementById('reopenOfferForm');
            form.action = '/Offer/ReopenOffer/' + offerId;
            new bootstrap.Modal(document.getElementById('reopenOfferModal')).show();
        }

        function openDeleteModal(offerId, offerTitle) {
            document.getElementById('deleteOfferTitle').innerText = offerTitle;
            const form = document.getElementById('deleteOfferForm');
            form.action = '/Offer/Delete/' + offerId;
            new bootstrap.Modal(document.getElementById('deleteOfferModal')).show();
        }

        function checkStatus() {
            const pendingElements = document.querySelectorAll('.ai-status-pending');

            pendingElements.forEach(el => {
                const offerId = el.getAttribute('data-offer-id');

                fetch(`/Offer/GetAiStatus/${offerId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.status === "Verified") {
                            updateRowToVerified(offerId);
                        }
                    })
                    .catch(error => console.error('Error fetching status:', error));
            });
        }

        function updateRowToVerified(id) {
            const row = document.getElementById(`row-${id}`);
            if (row) {
                row.classList.remove('bg-light-subtle');
                row.classList.add('bg-success-subtle');
            }

            const titleBadge = document.getElementById(`verified-badge-${id}`);
            if (titleBadge) {
                titleBadge.innerHTML = `<span class="badge bg-success ms-2 small" style="font-size: 0.7rem;"><i class="bi bi-patch-check-fill me-1"></i>AI Verified</span>`;
            }

            const statusCont = document.getElementById(`status-container-${id}`);
            if (statusCont) {
                statusCont.innerHTML = `<span class="badge rounded-pill bg-success px-3 py-2">Analysis Ready</span>`;
            }

            const btnCont = document.getElementById(`ai-button-container-${id}`);
            if (btnCont) {
                btnCont.innerHTML = `
                    <a href="/Offer/AiAnalysisDetails/${id}" class="btn btn-link btn-sm p-2 text-success" title="View AI Analysis Results">
                        <i class="bi bi-robot fs-5"></i>
                        <i class="bi bi-check-circle-fill" style="font-size: 0.6rem; vertical-align: top; margin-left: -8px;"></i>
                    </a>`;
            }
        }

        setInterval(() => {
            if (document.querySelectorAll('.ai-status-pending').length > 0) {
                checkStatus();
            }
        }, 3000);
    </script>
}