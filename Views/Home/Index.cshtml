@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}
@model List<string>
@{
    ViewData["Title"] = "Home Page";

    var categoryIcons = new Dictionary<string, string>
    {
        { "IT", "bi-cpu" },
        { "Data Science", "bi-graph-up-arrow" },
        { "Marketing", "bi-megaphone" },
        { "Finance", "bi-cash-coin" },
        { "Healthcare", "bi-hospital" },
        { "Engineering", "bi-tools" },
        { "Sales", "bi-currency-exchange" },
        { "Customer Service", "bi-headset" },
        { "Human Resources", "bi-people" },
        { "Design & Creative", "bi-palette" },
        { "Logistics", "bi-truck" },
        { "Legal", "bi-shield-check" },
        { "Education", "bi-mortarboard" },
        { "Construction", "bi-building-gear" },
        { "Hospitality", "bi-cup-hot" },
        { "Other", "bi-three-dots" }
    };
}

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Find Your <span class="text-dark">Next Career</span></h1>
        <p class="text-muted fs-5">Powered by AI to match you with the best opportunities.</p>
    </div>

    <div class="row g-3">
        @foreach (var category in Model)
        {
            var iconClass = categoryIcons.ContainsKey(category) ? categoryIcons[category] : categoryIcons["Default"];
            
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm transition-hover text-center p-3">
                    <div class="card-body d-flex flex-column align-items-center">
                        <div class="icon-shape bg-light-primary text-primary rounded-circle mb-3">
                            <i class="bi @iconClass fs-2"></i>
                        </div>
                        <h5 class="card-title fw-bold mb-2">@category</h5>
                        <p class="text-muted small mb-4">Explore high-paying roles in the @category sector.</p>
                        <a asp-controller="Offer" asp-action="List" asp-route-category="@category"
                               class="btn btn-primary rounded-pill px-4 mt-auto fw-bold btn-sm py-2">
                            View Offers
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
