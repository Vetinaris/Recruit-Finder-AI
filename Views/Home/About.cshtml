@{
    ViewData["Title"] = "About RecruitFinder AI";
}

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-lg-6">
            <h1 class="display-4 fw-bold text-primary mb-4">Smart Recruitment <br /><span class="text-dark">Driven by AI</span></h1>
            <p class="lead text-secondary mb-4">
                RecruitFinder AI is a cutting-edge platform designed for employers to streamline their hiring process.
                Our advanced AI algorithms analyze every submitted CV to find the perfect match for your job requirements.
            </p>
            <div class="d-flex gap-3 mb-4">
                <div class="text-center p-3 bg-white shadow-sm rounded-4 border-bottom border-primary border-3">
                    <i class="bi bi-cpu fs-2 text-primary"></i>
                    <p class="small fw-bold mb-0 mt-2">AI Analysis</p>
                </div>
                <div class="text-center p-3 bg-white shadow-sm rounded-4 border-bottom border-success border-3">
                    <i class="bi bi-graph-up-arrow fs-2 text-success"></i>
                    <p class="small fw-bold mb-0 mt-2">Best Match</p>
                </div>
                <div class="text-center p-3 bg-white shadow-sm rounded-4 border-bottom border-info border-3">
                    <i class="bi bi-clock-history fs-2 text-info"></i>
                    <p class="small fw-bold mb-0 mt-2">Time Saving</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <img src="~/images/pexels-fauxels-3184632.jpg" alt="Recruitment AI" class="img-fluid">
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        <div class="col-md-4">
            <div class="h-100 p-4 bg-white rounded-4 shadow-sm border-0">
                <h4 class="fw-bold"></i>Post an Offer</h4>
                <p class="text-muted">Create detailed job descriptions including specific skills and requirements.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="h-100 p-4 bg-white rounded-4 shadow-sm border-0">
                <h4 class="fw-bold"></i>AI Scanning</h4>
                <p class="text-muted">Our AI scans resumes to extract skills, experience, and educational background automatically.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="h-100 p-4 bg-white rounded-4 shadow-sm border-0">
                <h4 class="fw-bold"></i>Get the Best</h4>
                <p class="text-muted">Receive a ranked list of candidates who are the best fit for your specific position.</p>
            </div>
        </div>
    </div>
</div>