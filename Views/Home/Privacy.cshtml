@{
    ViewData["Title"] = "Privacy Policy"; 
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="text-center mb-5">
                <i class="bi bi-lock-fill text-primary display-1 mb-3"></i>
                <h1 class="fw-bold">@ViewData["Title"]</h1> 
                <p class="text-muted">Last updated: March 2026</p>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="accordion accordion-flush" id="privacyAccordion">
                        
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec1">
                                    1. Data We Collect
                                </button>
                            </h2>
                            <div id="sec1" class="accordion-collapse collapse show" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 text-secondary">
                                    We collect information that you provide directly to us, including your email, company name, and any resume data uploaded for AI analysis.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec2">
                                    2. How AI Processes Your Data
                                </button>
                            </h2>
                            <div id="sec2" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 text-secondary">
                                    Our AI models analyze resume content to extract skills and experience. This data is used solely to match candidates with job offers.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec3">
                                    3. Data Security
                                </button>
                            </h2>
                            <div id="sec3" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 text-secondary">
                                    We implement industry-standard security measures to protect your personal information from unauthorized access or disclosure.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">
                    Questions about our policy? <a href="mailto:privacy@recruitfinder.ai" class="text-primary text-decoration-none fw-bold">Contact our DPO</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .accordion-button:not(.collapsed) {
        background-color: #f8faff;
        color: #4361ee;
    }
    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(0,0,0,.125);
    }
</style>