@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <div class="bg-primary text-white mb-3 mx-auto icon-circle shadow-sm">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <h1 class="fw-bold text-dark">@ViewData["Title"]</h1>
                <p class="text-muted">Your trust is our priority. Learn how RecruitFinder AI protects your professional data.</p>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill small">
                        <i class="bi bi-calendar3 me-2"></i>Last updated: May 2026
                    </span>
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill small">
                        <i class="bi bi-patch-check-fill text-primary me-2"></i>GDPR Compliant
                    </span>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="accordion accordion-flush" id="privacyAccordion">
                        
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec1">
                                    1. Data Collection & CV Creator
                                </button>
                            </h2>
                            <div id="sec1" class="accordion-collapse collapse show" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 pb-4 text-secondary lh-lg">
                                    When you use our <strong>AI CV Creator</strong>, we collect information necessary to build your professional profile:
                                    <ul class="mt-2">
                                        <li><strong>Identity Data:</strong> Full name, contact details, and links to professional profiles (e.g., LinkedIn).</li>
                                        <li><strong>Experience Data:</strong> Work history, education, and skills you input or upload via files.</li>
                                        <li><strong>Generated Content:</strong> We store the CVs you create so you can edit and download them in PDF format at any time.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec2">
                                    2. How AI Processes Your Professional Data
                                </button>
                            </h2>
                            <div id="sec2" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 pb-4 text-secondary lh-lg">
                                    Our AI algorithms analyze your input to provide:
                                    <ul class="mt-2">
                                        <li><strong>Optimization Suggestions:</strong> Improving the language and impact of your resume.</li>
                                        <li><strong>Skill Extraction:</strong> Automatically identifying key competencies for recruiter matching.</li>
                                        <li><strong>Objective Screening:</strong> Assisting recruiters in finding the best fit based on merit.</li>
                                    </ul>
                                    <p class="small bg-light p-3 rounded-3 mt-2">
                                        <i class="bi bi-info-circle me-2 text-primary"></i> <strong>Important:</strong> Your personal data is never used to train public AI models. All processing stays within our secure environment.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec3">
                                    3. Data Sharing & PDF Exports
                                </button>
                            </h2>
                            <div id="sec3" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 pb-4 text-secondary lh-lg">
                                    We respect your ownership of your data:
                                    <ul class="mt-2">
                                        <li><strong>Personal Use:</strong> CVs generated on our platform and downloaded as PDF are for your personal use.</li>
                                        <li><strong>Employer Access:</strong> Your profile is only visible to recruiters when you explicitly apply for a job or set your profile to "Visible."</li>
                                        <li><strong>No Selling:</strong> We never sell your personal information to third-party advertisers.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold px-4 py-4" type="button" data-bs-toggle="collapse" data-bs-target="#sec4">
                                    4. Your Rights & Data Portability
                                </button>
                            </h2>
                            <div id="sec4" class="accordion-collapse collapse" data-bs-parent="#privacyAccordion">
                                <div class="accordion-body px-4 pb-4 text-secondary lh-lg">
                                    As a user of RecruitFinder AI, you have the right to:
                                    <ul class="mt-2">
                                        <li><strong>Access & Download:</strong> Export all your data and generated resumes at any time.</li>
                                        <li><strong>Right to Erasure:</strong> Delete your account and all associated CV files permanently.</li>
                                        <li><strong>Encryption:</strong> All files and data are protected using industry-standard AES-256 encryption.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <p class="text-muted">Questions regarding your data?</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="mailto:privacy@recruitfinder.ai" class="btn btn-primary rounded-pill px-4 hover-lift">
                        <i class="bi bi-envelope-at me-2"></i> Contact DPO
                    </a>
                    <a asp-controller="Home" asp-action="TermsOfService"
                           class="btn btn-outline-secondary rounded-pill px-4 hover-lift d-inline-flex align-items-center justify-content-center">
                        Read Terms
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
