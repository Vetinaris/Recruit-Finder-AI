<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecruitFinder AI</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Recruit_Finder_AI.styles.css" asp-append-version="true" />

    <style>
            :root {
                --primary-ai: #4361ee;
                --secondary-ai: #3f37c9;
                --bg-light: #f8f9fa;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--bg-light);
                color: #2b2d42;
            }

            .navbar {
                background-color: rgba(255, 255, 255, 0.95) !important;
                backdrop-filter: blur(10px);
                border-bottom: 1px solid #e9ecef;
            }

            .navbar-brand {
                font-weight: 700;
                letter-spacing: -0.5px;
            }

            .nav-link {
                font-weight: 500;
                color: #4a4e69 !important;
                transition: color 0.2s;
            }

                .nav-link:hover {
                    color: var(--primary-ai) !important;
                }

            footer {
                background-color: #ffffff;
                border-top: 1px solid #e9ecef;
                padding: 1rem 0;
            }

            .main-container {
                min-height: calc(100vh - 160px);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand text-primary d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cpu-fill me-2 fs-3"></i>
                    <span>RecruitFinder <span class="text-dark">AI</span></span>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Offer" asp-action="MyListings">
                                <i class="bi bi-briefcase me-1"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="About">
                                <i class="bi bi-info-circle me-1"></i> How it works
                            </a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-muted mt-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="fw-bold text-primary">RecruitFinder AI</span> &copy; 2026 - All Rights Reserved
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <a class="text-decoration-none text-muted me-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a href="#" class="text-muted fs-5"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>