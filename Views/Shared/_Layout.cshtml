<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecruitFinder AI</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/account.css" />
    <link rel="stylesheet" href="~/Recruit_Finder_AI.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand text-primary d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="bg-primary text-white rounded-3 p-1 me-2 d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; background: linear-gradient(135deg, var(--primary-ai), var(--secondary-ai)) !important;">
                        <i class="bi bi-cpu-fill fs-5"></i>
                    </div>
                    <span>RecruitFinder<span class="text-dark">AI</span></span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-between" id="mainNavbar">
                    <ul class="navbar-nav">
                        @if (!(User.IsInRole("ADMIN") || User.IsInRole("MODERATOR")))
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center justify-content-center" asp-area="" asp-controller="Home" asp-action="Index" style="height: 40px;">
                                    <i class="bi bi-house-door me-2"></i> Home
                                </a>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated && User.IsInRole("ADMIN"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" data-bs-toggle="dropdown" style="color: var(--admin-accent) !important;">
                                    <i class="bi bi-shield-lock me-2"></i> Admin
                                </a>
                                <ul class="dropdown-menu border-0" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Users</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="AuditLogs">Logs</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings">Settings</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Guidelines">Guidelines</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated && User.IsInRole("MODERATOR"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="modDropdown" data-bs-toggle="dropdown" style="color: var(--mod-accent) !important;">
                                    <i class="bi bi-shield-lock me-2"></i> Mod
                                </a>
                                <ul class="dropdown-menu border-0" aria-labelledby="modDropdown">
                                    <li><a class="dropdown-item" asp-controller="Moderator" asp-action="Index">Verify Companies</a></li>
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="Index">Review Job Offers</a></li>
                                    <li><a class="dropdown-item" asp-controller="Moderator" asp-action="Guidelines">Guidelines</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.Identity.IsAuthenticated && !User.IsInRole("ADMIN") && !User.IsInRole("MODERATOR"))
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center justify-content-center" asp-controller="Cv" asp-action="Index" style="height: 40px;">
                                    <i class="bi bi-file-earmark-person me-2"></i> My CV
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center justify-content-center" asp-controller="Offer" asp-action="MyListings" style="height: 40px;">
                                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                                </a>
                            </li>
                        }

                        @if (!(User.IsInRole("ADMIN") || User.IsInRole("MODERATOR")))
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center justify-content-center" asp-controller="Home" asp-action="About" style="height: 40px;">
                                    <i class="bi bi-info-circle me-2"></i> How it works
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-lg-flex align-items-center">
                        <ul class="navbar-nav ms-auto align-items-center">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item me-lg-2">
                                    <a class="nav-link d-flex align-items-center justify-content-center" asp-controller="Notifications" asp-action="Index"
                                           style="height: 40px;">
                                        <i class="bi bi-bell me-2"></i> Notifications
                                        @await Component.InvokeAsync("NotificationBadge")
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <partial name="_LoginPartial" />
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container pt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <div class="row align-items-center text-center text-md-start">
                <div class="col-md-6">
                    <p class="mb-0 fw-600 text-dark">RecruitFinder <span class="text-primary">AI</span></p>
                    <small class="text-muted">Connecting talent with intelligence &copy; 2026</small>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a class="text-muted text-decoration-none small" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <span class="text-muted mx-2 small">&middot;</span>
                    <a class="text-muted text-decoration-none small hover-link" asp-controller="Home" asp-action="TermsOfService">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>