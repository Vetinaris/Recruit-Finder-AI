@model IEnumerable<Recruit_Finder_AI.Entities.AuditLog>
@{
    ViewData["Title"] = "System Audit Logs";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold"><i class="bi bi-journal-text text-primary me-2"></i>System Audit Logs</h2>
            <p class="text-muted">Review full details of security events and AI system operations.</p>
        </div>
        <a asp-action="ExportAuditLogs" class="btn btn-outline-primary rounded-pill shadow-sm transition-hover">
            <i class="bi bi-download me-2"></i>Export Logs
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th style="width: 15%" class="ps-4">Timestamp</th>
                        <th style="width: 15%">User</th>
                        <th style="width: 10%">Action</th>
                        <th style="width: 10%">Status</th>
                        <th style="width: 10%">IP Address</th>
                        <th style="width: 40%" class="pe-4">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4 small text-muted">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="fw-bold">@log.UserName</td>
                            <td><span class="badge bg-light text-dark border">@log.Action</span></td>
                            <td>
                                @if (log.IsSuccess)
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">Success</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Failed</span>
                                }
                            </td>
                            <td class="font-monospace small">@log.IpAddress</td>
                            <td class="pe-4 py-3">
                                <div class="text-wrap" style="word-break: break-all; min-width: 300px; font-size: 0.85rem; color: #4a4a4a;">
                                    @log.Details
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.2s ease-in-out;
    }
    .transition-hover:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
    }
    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>