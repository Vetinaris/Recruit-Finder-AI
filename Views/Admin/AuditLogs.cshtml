@model IEnumerable<Recruit_Finder_AI.Entities.AuditLog>
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "System Audit Logs";
}

<div class="container py-5">
    <div class="row align-items-center mb-5 gy-4">
        <div class="col-lg-6 text-center text-lg-start">
            <h1 class="fw-bold display-6 mb-1">System Audit Logs</h1>
            <p class="text-muted mb-0">
                Tracking <span class="fw-bold text-primary">@Model.Count()</span> security and administrative events.
            </p>
        </div>
        
        <div class="col-lg-6">
            <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-end gap-3">
                <a asp-action="ExportAuditLogs" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                    <i class="bi bi-download me-2"></i>Export CSV
                </a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table" style="min-width: 900px;">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted" style="width: 250px;">Timestamp</th>
                        <th class="py-3 text-uppercase small fw-bold text-center" style="width: 200px;">User</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Action</th>
                        <th class="py-3 text-uppercase small fw-bold text-center text-center" style="width: 1px; white-space: nowrap;">Status</th>
                        <th class="py-3 text-uppercase small fw-bold text-center pe-4" style="width: 400px;">Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-shield-slash text-muted display-1 mb-3 d-block"></i>
                                    <h4 class="fw-bold text-muted">No activity logs found</h4>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-soft-primary text-primary rounded-3 me-3 flex-shrink-0" style="width: 40px; height: 40px;">
                                        <i class="bi bi-calendar3"></i>
                                    </div>
                                    <div class="small fw-semibold text-dark">
                                        @log.Timestamp.ToString("dd MMM yyyy")<br />
                                        <span class="text-muted fw-normal">@log.Timestamp.ToString("HH:mm:ss")</span>
                                    </div>
                                </div>
                            </td>

                            <td class="text-center">
                                <div class="fw-bold text-dark">@log.UserName</div>
                            </td>

                            <td class="text-center">
                                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 fw-semibold">
                                    @log.Action
                                </span>
                            </td>

                            <td class="text-center">
                                @if (log.IsSuccess)
                                {
                                    <span class="badge bg-soft-success text-success rounded-pill px-3 py-2 border border-success border-opacity-10">
                                        Success
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-soft-danger text-danger rounded-pill px-3 py-2 border border-danger border-opacity-10">
                                        Failed
                                    </span>
                                }
                            </td>

                            <td class="pe-4">
                                <div class="glass-details p-3 rounded-pill px-3 border border-white shadow-sm">
                                    <div class="d-flex align-items-start">
                                        <div class="text-dark small lh-sm">
                                            @log.Details
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
