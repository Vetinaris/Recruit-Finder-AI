@model IEnumerable<Recruit_Finder_AI.Entities.AuditLog>

@{
    ViewData["Title"] = "System Audit Logs";
}

<h2>System Audit Logs</h2>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Timestamp</th>
            <th>User (UserName)</th>
            <th>Action</th>
            <th>Success</th>
            <th>Details</th>
            <th>IP Address</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr class="@(log.IsSuccess ? "" : "table-danger")">
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@log.UserName</td>
                <td>@log.Action</td>
                <td>@(log.IsSuccess ? "Yes" : "No")</td>
                <td>@log.Details</td>
                <td>@log.IpAddress</td>
            </tr>
        }
    </tbody>
</table>