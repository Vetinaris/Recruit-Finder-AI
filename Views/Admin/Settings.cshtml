@model Recruit_Finder_AI.ViewModels.AdminSettingsViewModel

<h2><i class="bi bi-shield-lock"></i> Global Security Policy</h2>

<form asp-action="Settings" method="post">
    <div class="card mb-3 shadow-sm">
        <div class="card-header bg-primary text-white">Password Requirements</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MinPasswordLength" class="fw-bold">Minimum Password Length</label>
                    <input asp-for="MinPasswordLength" class="form-control" type="number" min="6" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PasswordExpirationDays" class="fw-bold">Expire Passwords After (Days)</label>
                    <input asp-for="PasswordExpirationDays" class="form-control" type="number" />
                </div>
            </div>
            <div class="form-group">
                <label asp-for="PasswordHistoryDepth" class="fw-bold">Password History (Cannot reuse last X)</label>
                <input asp-for="PasswordHistoryDepth" class="form-control" type="number" />
            </div>
        </div>
    </div>

    <div class="card mb-3 shadow-sm">
        <div class="card-header bg-dark text-white">System Access</div>
        <div class="card-body">
            <div class="form-check form-switch">
                <input asp-for="EnableRegistration" class="form-check-input" type="checkbox" role="switch">
                <label asp-for="EnableRegistration" class="form-check-label">Enable Public Registration</label>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-success px-5">Save Policy</button>
</form>