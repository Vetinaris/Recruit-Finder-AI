@model Recruit_Finder_AI.ViewModels.AdminSettingsViewModel
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Global Policy";
}

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-0">Global Security Policy</h2>
            <p class="text-muted mb-0 small">Configure baseline security requirements for all users and AI data access.</p>
        </div>
    </div>

    <form asp-action="Settings" method="post">
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4" style="border: 1px solid #f8f9fa !important;">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="fw-bold text-dark mb-4 d-flex align-items-center">
                            <i class="bi bi-key text-primary me-2"></i> Password Requirements
                        </h5>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="MinPasswordLength" class="form-label small fw-bold text-muted text-uppercase ms-2">Min Password Length</label>
                                <input asp-for="MinPasswordLength" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2" type="number" min="6" />
                                <span asp-validation-for="MinPasswordLength" class="text-danger small ms-2"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="PasswordExpirationDays" class="form-label small fw-bold text-muted text-uppercase ms-2">Expiration Period (Days)</label>
                                <input asp-for="PasswordExpirationDays" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2" type="number" />
                                <span asp-validation-for="PasswordExpirationDays" class="text-danger small ms-2"></span>
                            </div>
                            
                            <div class="col-12">
                                <label asp-for="PasswordHistoryDepth" class="form-label small fw-bold text-muted text-uppercase ms-2">Password History Depth</label>
                                <input asp-for="PasswordHistoryDepth" class="form-control rounded-pill border-light-subtle shadow-sm px-4 py-2" type="number" />
                                <div class="form-text text-muted small ms-2">Prevents users from reusing their last X passwords.</div>
                                <span asp-validation-for="PasswordHistoryDepth" class="text-danger small ms-2"></span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-lift fw-bold">
                        Save Policy Settings
                    </button>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4" style="border: 1px solid #f8f9fa !important;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-4 border-bottom pb-3">
                            <i class="bi bi-gear-wide-connected text-primary me-2"></i> System Access
                        </h5>
                        
                        <div class="form-check form-switch custom-switch mb-3">
                            <input asp-for="EnableRegistration" class="form-check-input" type="checkbox" role="switch" id="registrationSwitch">
                            <label asp-for="EnableRegistration" class="form-check-label fw-bold text-dark ms-2" for="registrationSwitch">Public Registration</label>
                        </div>
                        
                        <div class="bg-light p-3 rounded-4 mt-3">
                            <p class="small text-muted mb-0">
                                <i class="bi bi-info-circle-fill text-primary me-1"></i>
                                When disabled, only admins can create new employer or recruiter accounts.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
