@model Recruit_Finder_AI.ViewModels.AdminSettingsViewModel
@{
    ViewData["Title"] = "Global Policy";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="fw-bold"><i class="bi bi-shield-check text-primary me-2"></i>Global Security Policy</h2>
        <p class="text-muted">Configure baseline security requirements for all users and AI data access.</p>
    </div>

    <form asp-action="Settings" method="post">
        <div class="row g-4">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Password Requirements</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="MinPasswordLength" class="form-label fw-medium">Min Password Length</label>
                                <input asp-for="MinPasswordLength" class="form-control rounded-3" type="number" min="6" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PasswordExpirationDays" class="form-label fw-medium">Expiration Period (Days)</label>
                                <input asp-for="PasswordExpirationDays" class="form-control rounded-3" type="number" />
                            </div>
                            <div class="col-12">
                                <label asp-for="PasswordHistoryDepth" class="form-label fw-medium">Password History Depth</label>
                                <input asp-for="PasswordHistoryDepth" class="form-control rounded-3" type="number" />
                                <div class="form-text">Prevents users from reusing their last X passwords.</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-sm">
                    <i class="bi"></i>Save Policy Settings
                </button>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4 border-bottom border-secondary pb-2">System Access</h5>
                        <div class="form-check form-switch mb-3 mt-4">
                            <input asp-for="EnableRegistration" class="form-check-input" type="checkbox" role="switch">
                                <label asp-for="EnableRegistration" class="form-check-label">Public Registration</label>
                            </div>
                            <p class="small text-secondary mb-0">When disabled, only admins can create new employer or recruiter accounts.</p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>