@model Recruit_Finder_AI.ViewModels.EditUserViewModel
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Edit User | " + Model.Email;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-11">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="d-flex align-items-center">
                    <a asp-action="Index" class="btn btn-outline-primary rounded-circle me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-arrow-left fs-5"></i>
                    </a>
                    <div>
                        <h2 class="fw-bold mb-0 text-dark">User Management</h2>
                        <p class="text-muted mb-0 small text-uppercase fw-bold">Modifying: <span class="text-primary">@Model.Email</span></p>
                    </div>
                </div>
                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">
                    <i class="bi bi-shield-check me-1"></i> Admin Console
                </span>
            </div>

            <form asp-action="EditUser" method="post" id="editUserForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 shadow-sm mb-4"></div>
                
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserName" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="PhoneNumber" />

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-body p-4 p-md-5">
                                <h5 class="fw-bold mb-4 d-flex align-items-center">
                                    <span class="icon-shape bg-soft-primary text-primary rounded-3 me-3">
                                        <i class="bi bi-person-vcard"></i>
                                    </span>
                                    Contact Details
                                </h5>
                                
                                <div class="row mb-4 g-3">
                                    <div class="col-sm-7">
                                        <label class="small text-muted text-uppercase fw-bold d-block mb-1">Email Address</label>
                                        <div class="p-3 bg-light rounded-3 fw-semibold border-start border-primary border-4">
                                            <i class="bi bi-envelope me-2 text-primary"></i>@Model.Email
                                        </div>
                                    </div>
                                    <div class="col-sm-5">
                                        <label class="small text-muted text-uppercase fw-bold d-block mb-1">Phone Number</label>
                                        <div class="p-3 bg-light rounded-3 fw-semibold border-start border-primary border-4">
                                            <i class="bi bi-telephone me-2 text-primary"></i>
                                            @(Model.PhoneNumber ?? "—")
                                        </div>
                                    </div>
                                </div>

                                <hr class="my-5 opacity-25">

                                <h5 class="fw-bold mb-4 d-flex align-items-center">
                                    <span class="icon-shape bg-soft-success text-success rounded-3 me-3">
                                        <i class="bi bi-building"></i>
                                    </span>
                                    Employer Settings
                                </h5>

                                <div class="form-check form-switch p-3 border rounded-4 mb-4 bg-light-subtle d-flex align-items-center justify-content-between px-4 shadow-sm border-dashed">
                                    <div>
                                        <label for="isEmployerSwitch" class="form-check-label fw-bold h6 mb-0">Verified Employer Status</label>
                                        <div class="form-text small">Requires all company details to be completed.</div>
                                    </div>
                                    <input asp-for="IsEmployer" class="form-check-input ms-0" type="checkbox" role="switch" id="isEmployerSwitch" style="width: 3.5rem; height: 1.75rem;">
                                </div>

                                <div id="employerFields" class="row g-3 @(Model.IsEmployer ? "" : "opacity-50")">
                                    <div class="col-md-6">
                                        <label asp-for="CompanyName" class="small text-muted text-uppercase fw-bold mb-1">Company Name *</label>
                                        <input asp-for="CompanyName" class="form-control rounded-3 border-light shadow-none bg-light employer-input no-emoji" />
                                        <div class="invalid-feedback">Company Name is required for employers.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="NIP" class="small text-muted text-uppercase fw-bold mb-1">NIP / Tax ID *</label>
                                        <input asp-for="NIP" class="form-control rounded-3 border-light shadow-none bg-light employer-input no-emoji" />
                                        <div class="invalid-feedback">NIP is required for employers.</div>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="CompanyAddress" class="small text-muted text-uppercase fw-bold mb-1">Registered Address *</label>
                                        <textarea asp-for="CompanyAddress" class="form-control rounded-3 border-light shadow-none bg-light employer-input no-emoji" rows="2"></textarea>
                                        <div class="invalid-feedback">Registered Address is required for employers.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 d-flex align-items-center">
                                    <span class="icon-shape bg-soft-warning text-warning rounded-3 me-3">
                                        <i class="bi bi-people"></i>
                                    </span>
                                    System Role <small class="text-muted fw-normal ms-2">(Select One)</small>
                                </h5>
                                <div class="row g-2">
                                    @for (int i = 0; i < Model.AvailableRoles.Count; i++)
                                    {
                                        <div class="col-md-6">
                                            <div class="role-card p-3 border rounded-3 transition-hover d-flex align-items-center bg-white">
                                                <input type="hidden" asp-for="@Model.AvailableRoles[i].RoleName" />
                                                <div class="form-check mb-0 w-100">
                                                    <input asp-for="@Model.AvailableRoles[i].IsSelected"
                                                           class="form-check-input cursor-pointer role-checkbox"
                                                           type="checkbox"
                                                           id="role_@i" />
                                                    <label class="form-check-label fw-semibold cursor-pointer ms-2 d-block" for="role_@i">
                                                        @Model.AvailableRoles[i].RoleName
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4 p-md-5">
                                <div class="card border-0 shadow-sm rounded-4 mb-4">
                                    <div class="card-body text-center p-4">
                                        <h6 class="fw-bold text-muted text-uppercase small mb-3">User Profile Photo</h6>
                                        @if (Model.ProfilePicture != null)
                                        {
                                            <img src="data:image/png;base64,@Convert.ToBase64String(Model.ProfilePicture)"
                                                 class="rounded-4 shadow-sm img-fluid" style="max-height: 200px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="py-5 bg-light rounded-4 border">
                                                <i class="bi bi-person-bounding-box fs-1 text-muted"></i>
                                                <p class="small text-muted mt-2 mb-0">No photo uploaded</p>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <h5 class="fw-bold mb-4 d-flex align-items-center text-dark">
                                    <span class="icon-shape bg-soft-danger text-danger rounded-3 me-3">
                                        <i class="bi bi-shield-lock-fill"></i>
                                    </span>
                                    Security Enforcement
                                </h5>

                                <div class="security-item p-4 rounded-4 mb-3 border bg-white shadow-sm transition-hover">
                                    <div class="form-check form-switch d-flex align-items-center justify-content-between p-0">
                                        <div>
                                            <label asp-for="IsLocked" class="form-check-label fw-bold mb-1 text-dark">Lock User Account</label>
                                            <p class="text-muted small mb-0">Instant access revocation.</p>
                                        </div>
                                        <input asp-for="IsLocked" class="form-check-input ms-0" type="checkbox" role="switch" style="width: 3.2rem; height: 1.6rem;">
                                    </div>
                                </div>

                                <div class="security-item p-4 rounded-4 mb-4 border bg-white shadow-sm transition-hover">
                                    <div class="form-check form-switch d-flex align-items-center justify-content-between p-0">
                                        <div>
                                            <label asp-for="ForcePasswordReset" class="form-check-label fw-bold mb-1 text-dark">Require Password Reset</label>
                                            <p class="text-muted small mb-0">Forces a change on next login.</p>
                                        </div>
                                        <input asp-for="ForcePasswordReset" id="forceResetSwitch" class="form-check-input ms-0" type="checkbox" role="switch" style="width: 3.2rem; height: 1.6rem;">
                                    </div>
                                </div>

                                <div class="mt-4 pt-2">
                                    <label asp-for="PasswordExpiration" class="form-label fw-bold text-muted small text-uppercase">Manual Expiration Limit</label>
                                    <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                                        <span class="input-group-text bg-light border-0 text-primary">
                                            <i class="bi bi-calendar-x"></i>
                                        </span>
                                        <input asp-for="PasswordExpiration" type="datetime-local" id="expirationInput" class="form-control border-0 bg-white fw-semibold shadow-none py-2" />
                                    </div>
                                    <div class="form-text text-muted small mt-2">
                                        <i class="bi bi-info-circle me-1"></i> Leave blank for permanent validity.
                                    </div>
                                </div>

                                <div class="mt-5 pt-3 d-grid">
                                    <button type="submit" id="submitBtn" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow-sm transition-btn">
                                        Apply Changes
                                    </button>
                                    <p class="text-center mt-3 text-muted small">
                                        Changes tracked in <a asp-action="AuditLogs" class="text-primary text-decoration-none fw-bold">System Audit</a>.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById('editUserForm');
            const employerSwitch = document.getElementById('isEmployerSwitch');
            const employerFields = document.getElementById('employerFields');
            const employerInputs = document.querySelectorAll('.employer-input');
            const roleCheckboxes = document.querySelectorAll('.role-checkbox');
            const forceResetSwitch = document.getElementById('forceResetSwitch');
            const expirationInput = document.getElementById('expirationInput');

            roleCheckboxes.forEach(cb => {
                if(cb.checked) cb.closest('.role-card').classList.add('selected');
                cb.addEventListener('change', function() {
                    if (this.checked) {
                        roleCheckboxes.forEach(other => {
                            if (other !== this) {
                                other.checked = false;
                                other.closest('.role-card').classList.remove('selected');
                            }
                        });
                        this.closest('.role-card').classList.add('selected');
                    } else {
                        this.closest('.role-card').classList.remove('selected');
                    }
                });
            });

            const emojiRegex = /[\u{1F600}-\u{1F64F}\u{1F300}-\u{1F5FF}\u{1F680}-\u{1F6FF}\u{1F700}-\u{1F77F}\u{1F780}-\u{1F7FF}\u{1F800}-\u{1F8FF}\u{1F900}-\u{1F9FF}\u{1FA00}-\u{1FA6F}\u{1FA70}-\u{1FAFF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}]/gu;
            document.querySelectorAll('.no-emoji').forEach(input => {
                input.addEventListener('input', function() {
                    this.value = this.value.replace(emojiRegex, '');
                });
            });

            forceResetSwitch.addEventListener("change", function () {
                if (!this.checked) {
                    expirationInput.value = "";
                } else {
                    if (!expirationInput.value) {
                        const now = new Date();
                        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                        expirationInput.value = now.toISOString().slice(0, 16);
                    }
                }
            });

            employerSwitch.addEventListener('change', function() {
                if (this.checked) {
                    employerFields.classList.remove('opacity-50');
                } else {
                    employerFields.classList.add('opacity-50');
                    employerInputs.forEach(i => i.classList.remove('is-invalid'));
                }
            });

            form.addEventListener('submit', function(e) {
                let isValid = true;
                if (employerSwitch.checked) {
                    employerInputs.forEach(input => {
                        if (!input.value.trim()) {
                            input.classList.add('is-invalid');
                            isValid = false;
                        } else {
                            input.classList.remove('is-invalid');
                        }
                    });
                }
                if (!isValid) {
                    e.preventDefault();
                    document.querySelector('.is-invalid').scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            });

            employerInputs.forEach(input => {
                input.addEventListener('input', function() {
                    if (this.value.trim()) this.classList.remove('is-invalid');
                });
            });
        });
    </script>
}