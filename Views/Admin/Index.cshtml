@model Recruit_Finder_AI.ViewModels.AdminIndexViewModel

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill me-2"></i>User Management</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        bool isLocked = user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow;
                        <tr>
                            <td class="fw-bold">@user.UserName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge border text-dark">@user.PrimaryRole</span>
                            </td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border border-success">Active</span>
                                }
                            </td>
                            <td class="text-end px-4">
                                <div class="btn-group">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary" title="Edit User">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>

                                    @if (isLocked)
                                    {
                                        <form asp-action="UnlockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-info" onclick="return confirm('Unlock user account?')">
                                                <i class="bi bi-unlock"></i> Unlock
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="LockUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" onclick="return confirm('Lock user account?')">
                                                <i class="bi bi-lock"></i> Lock
                                            </button>
                                        </form>
                                    }

                                    <form asp-action="ForcePasswordReset" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Force Password Reset">
                                            <i class="bi bi-key"></i> Reset
                                        </button>
                                    </form>

                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Permanently delete this user?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>