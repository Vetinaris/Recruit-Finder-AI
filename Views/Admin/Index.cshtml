@model Recruit_Finder_AI.ViewModels.AdminIndexViewModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid py-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h2 class="fw-bold"><i class="bi bi-people-fill text-primary me-2"></i>User Management</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="input-group-text bg-white border-0 ps-3">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="userSearch" class="form-control border-0 py-2" placeholder="Search by name or email...">
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="d-flex gap-2 h-100">
                <button class="btn btn-white shadow-sm rounded-pill px-3 filter-btn active" onclick="filterUsers('all', this)">
                    All
                </button>
                <button class="btn btn-white shadow-sm rounded-pill px-3 filter-btn" onclick="filterUsers('active', this)">
                    Active
                </button>
                <button class="btn btn-white shadow-sm rounded-pill px-3 filter-btn" onclick="filterUsers('banned', this)">
                    Blocked
                </button>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="userTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Account</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        bool isLocked = user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow;
                        string rowClass = isLocked ? "user-banned opacity-75 bg-light" : "user-active";
                        string statusTag = isLocked ? "banned" : "active";

                        <tr class="user-row @rowClass" data-status="@statusTag" data-search="@user.UserName.ToLower() @user.Email.ToLower()">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3 @(isLocked ? "bg-secondary" : "bg-primary")">
                                        @user.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold @(isLocked ? "text-decoration-line-through text-muted" : "")">@user.UserName</div>
                                        <div class="small text-muted">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-soft-primary text-primary rounded-pill px-3">@user.PrimaryRole</span></td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="badge bg-danger text-white rounded-pill px-3" data-bs-toggle="tooltip" title="Powód: @(user.BanReason ?? "Nieokreślony")">
                                        <i class="bi bi-shield-lock-fill me-1"></i> Locked
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success text-white rounded-pill px-3">
                                        <i class="bi bi-check-circle-fill me-1"></i> Active
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" 
                                       class="btn btn-action btn-soft-primary" title="Edit User">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    @if (isLocked)
                                    {
                                        <button type="button" class="btn btn-action btn-soft-info" 
                                                onclick="openUnlockModal('@user.Id', '@user.UserName', '@(user.BanReason ?? "Brak powodu")', '@(user.LockoutEnd.HasValue ? user.LockoutEnd.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "")', @(user.IsPermanentBan.ToString().ToLower()))"
                                                title="Odblokuj użytkownika">
                                            <i class="bi bi-unlock-fill"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-action btn-soft-danger" 
                                                onclick="openBanModal('@user.Id', '@user.UserName')" title="Zablokuj użytkownika">
                                            <i class="bi bi-slash-circle-fill"></i>
                                        </button>
                                    }

                                    <button type="button" class="btn btn-action btn-soft-warning" 
                                            onclick="openResetModal('@user.Id', '@user.UserName')" title="Force Password Reset">
                                        <i class="bi bi-key-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="banModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form id="banForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalUserId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Ban: <span id="modalUserName" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Ban Type</label>
                        <select class="form-select border-2 shadow-sm rounded-3" name="type" id="banType" onchange="updateBanUI()">
                            <option value="temp">Temporary (Months)</option>
                            <option value="perma">Permanent (Permanent Ban)</option>
                        </select>
                    </div>

                    <div id="monthsContainer" class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Ban Duration</label>
                        <select class="form-select border-2 shadow-sm rounded-3" name="months">
                            <option value="1">1 months</option>
                            <option value="3">3 months</option>
                            <option value="6">6 months</option>
                            <option value="12">1 year</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-uppercase text-muted">Ban Reason</label>
                        <select class="form-select border-2 shadow-sm rounded-3" name="reason" id="banReason" onchange="toggleCustomReason()">
                            <option value="Violation of service terms">Violation of service terms</option>
                            <option value="Spam and unwanted content">Spam and unwanted content</option>
                            <option value="Attempted data theft (Phishing)">Attempted data theft (Phishing)</option>
                            <option value="Hate speech / Profanity">Hate speech / Profanity</option>
                            <option value="Other (requires description)">Other (requires description)</option>
                        </select>
                    </div>

                    <div id="customReasonContainer" class="mb-3 d-none animate__animated animate__fadeIn">
                        <label class="form-label small fw-bold text-uppercase text-muted text-danger">Describe the reason</label>
                        <textarea name="customReason" class="form-control border-danger shadow-sm rounded-3" rows="3" placeholder="Explanation required..."></textarea>
                    </div>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="submitBanBtn" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">Apply Ban</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="unlockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="icon-shape bg-soft-info text-info rounded-circle mb-3 mx-auto" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                    <i class="bi bi-unlock-fill"></i>
                </div>
                <h4 class="fw-bold">Unlock Account?</h4>
                <p class="text-muted">You are about to restore access for <strong id="unlockUserName" class="text-dark"></strong>.</p>
                
                <div class="bg-light p-3 rounded-4 mb-4 text-start small">
                    <div class="mb-1 text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Ban Type:</div>
                    <div id="unlockType" class="mb-2"></div>
    
                    <div class="mb-1 text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Ban Reason:</div>
                    <div id="unlockReason" class="fw-bold mb-2"></div>
    
                    <div class="mb-1 text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Expires:</div>
                    <div id="unlockExpiry" class="fw-bold text-danger"></div>
                </div>

                <form asp-action="UnlockUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="unlockUserId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-info text-white btn-lg rounded-pill fw-bold shadow-sm">Confirm Unlock</button>
                        <button type="button" class="btn btn-light btn-lg rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <div class="icon-shape bg-soft-warning text-warning rounded-circle mb-3 mx-auto" style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                    <i class="bi bi-key-fill"></i>
                </div>
                <h4 class="fw-bold">Force Password Reset?</h4>
                <p class="text-muted mb-4">User <strong id="resetUserName" class="text-dark"></strong> will be required to create a new password upon their next login attempt.</p>
                
                <form asp-action="ForcePasswordReset" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="resetUserId" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning text-dark btn-lg rounded-pill fw-bold shadow-sm">Confirm Reset</button>
                        <button type="button" class="btn btn-light btn-lg rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('userSearch').addEventListener('input', function (e) {
            const term = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('.user-row');
            rows.forEach(row => {
                const text = row.getAttribute('data-search');
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });

        function filterUsers(status, btn) {
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.classList.remove('active', 'btn-primary', 'text-white');
                b.classList.add('btn-white');
            });
            btn.classList.add('active', 'btn-primary', 'text-white');
            btn.classList.remove('btn-white');

            const rows = document.querySelectorAll('.user-row');
            rows.forEach(row => {
                if (status === 'all') row.classList.remove('d-none');
                else {
                    row.getAttribute('data-status') === status
                        ? row.classList.remove('d-none')
                        : row.classList.add('d-none');
                }
            });
        }

        function openBanModal(userId, userName) {
            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalUserName').innerText = userName;
            updateBanUI();
            new bootstrap.Modal(document.getElementById('banModal')).show();
        }

        function updateBanUI() {
            const type = document.getElementById('banType').value;
            const monthsContainer = document.getElementById('monthsContainer');
            const form = document.getElementById('banForm');
            const btn = document.getElementById('submitBanBtn');

            if (type === 'perma') {
                monthsContainer.style.display = 'none';
                form.action = '@Url.Action("PermaBan", "Admin")';
                btn.className = 'btn btn-dark rounded-pill px-4 fw-bold shadow-sm';
                btn.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>Nałóż PermaBan';
            } else {
                monthsContainer.style.display = 'block';
                form.action = '@Url.Action("TemporaryBan", "Admin")';
                btn.className = 'btn btn-danger rounded-pill px-4 fw-bold shadow-sm';
                btn.innerHTML = 'Apply Ban';
            }
        }

        function toggleCustomReason() {
            const reason = document.getElementById('banReason').value;
            const container = document.getElementById('customReasonContainer');
            if (reason === 'Other (requires description)') {
                container.classList.remove('d-none');
            } else {
                container.classList.add('d-none');
            }
        }

        function openUnlockModal(userId, userName, reason, expiry, isPerma) {
            document.getElementById('unlockUserId').value = userId;
            document.getElementById('unlockUserName').innerText = userName;
            document.getElementById('unlockReason').innerText = reason;
    
            const typeElement = document.getElementById('unlockType');
    
            if (isPerma) {
                typeElement.innerHTML = '<span class="badge bg-danger">Permanent Ban</span>';
                document.getElementById('unlockExpiry').innerText = "Never (Permanent)";
            } else {
                typeElement.innerHTML = '<span class="badge bg-warning text-dark">Temporary Ban</span>';
                document.getElementById('unlockExpiry').innerText = expiry; 
            }
    
            new bootstrap.Modal(document.getElementById('unlockModal')).show();
        }

        function openResetModal(userId, userName) {
            document.getElementById('resetUserId').value = userId;
            document.getElementById('resetUserName').innerText = userName;
            new bootstrap.Modal(document.getElementById('resetPasswordModal')).show();
        }

        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
    </script>
}

<style>
    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .btn-white {
        background: #fff;
        border: 1px solid #eee;
    }

        .btn-white:hover {
            background: #f8f9fa;
            border-color: #ddd;
        }

        .btn-white.active {
            background: #4361ee !important;
            color: white !important;
            border-color: #4361ee;
        }

    .avatar-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .user-banned .badge.bg-danger {
        cursor: help;
    }

    .form-select:focus, .form-control:focus {
        border-color: #4361ee;
        box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.1);
    }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .btn-action {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: none;
        transition: all 0.2s ease-in-out;
        font-size: 1rem;
    }

    .btn-action:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .btn-soft-primary {
        background-color: rgba(67, 97, 238, 0.15);
        color: #4361ee;
    }
    .btn-soft-primary:hover {
        background-color: #4361ee;
        color: white;
    }

    .btn-soft-danger {
        background-color: rgba(239, 35, 60, 0.15);
        color: #ef233c;
    }
    .btn-soft-danger:hover {
        background-color: #ef233c;
        color: white;
    }

    .btn-soft-info {
        background-color: rgba(13, 202, 240, 0.15);
        color: #0dcaf0;
    }
    .btn-soft-info:hover {
        background-color: #0dcaf0;
        color: white;
    }

    .btn-soft-warning {
        background-color: rgba(255, 193, 7, 0.15);
        color: #ffc107;
    }
    .btn-soft-warning:hover {
        background-color: #ffc107;
        color: #000;
    }

    .table td {
        vertical-align: middle;
    }
</style>