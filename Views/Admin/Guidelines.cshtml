@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Admin Guidelines";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="d-flex align-items-center mb-5">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Administrative Guidelines</h2>
                    <p class="text-muted mb-0 small">Standard operating procedures and system manual for Recruit Finder AI.</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-lg rounded-4 h-100 hover-lift-static">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 d-flex align-items-center text-primary">
                                <i class="bi bi-people-fill me-2"></i> User Management
                            </h5>
                            <ul class="list-group list-group-flush small">
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <strong>Role Assignment:</strong> Always ensure a user has at least one role. Employers require "Employer" status.
                                </li>
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <strong>Verification:</strong> Manual verification of NIP and Address is recommended before granting permanent status.
                                </li>
                                <li class="list-group-item border-0 px-0 py-2 bg-transparent">
                                    <i class="bi bi-check2-circle text-success me-2"></i>
                                    <strong>Account Edits:</strong> Metadata changes trigger security stamp updates for system integrity.
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card border-0 shadow-lg rounded-4 h-100 border-start border-danger border-5 hover-lift-static">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 d-flex align-items-center text-danger">
                                <i class="bi bi-shield-lock-fill me-2"></i> Security Enforcement
                            </h5>
                            <div class="accordion accordion-flush" id="securityAccordion">
                                <div class="accordion-item border-0 bg-transparent">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed px-0 py-2 fw-bold shadow-none bg-transparent text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#banInfo">
                                            Banning Policy
                                        </button>
                                    </h2>
                                    <div id="banInfo" class="accordion-collapse collapse" data-bs-parent="#securityAccordion">
                                        <div class="accordion-body px-0 py-2 small text-muted">
                                            <strong>Temporary Ban:</strong> For minor violations. Auto-unlocks after expiry.<br>
                                            <strong>Permanent Ban:</strong> For fraud or phishing. Only a super-admin can reverse this.
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item border-0 bg-transparent">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed px-0 py-2 fw-bold shadow-none bg-transparent text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#resetInfo">
                                            Password Resets
                                        </button>
                                    </h2>
                                    <div id="resetInfo" class="accordion-collapse collapse" data-bs-parent="#securityAccordion">
                                        <div class="accordion-body px-0 py-2 small text-muted">
                                            Force Password Reset invalidates the current password and redirects the user to the reset page on their next attempt.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden" style="background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%); border: 1px solid #f1f1f1 !important;">
                        <div class="card-body p-4 p-md-5">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                                        <i class="bi bi-database-fill-lock text-primary me-2"></i> Data & Audit Logs
                                    </h5>
                                    <p class="text-muted small mb-4">
                                        Every administrative action is logged (IP, Timestamp, User).
                                        <strong>Export Logs</strong> generates a secure CSV file.
                                        Do not delete audit logs unless strictly instructed by the CTO.
                                    </p>
                                    <div class="d-flex flex-wrap gap-3">
                                        <a asp-action="AuditLogs" class="btn btn-outline-primary rounded-pill px-4 fw-bold hover-lift d-inline-flex align-items-center justify-content-center">
                                            <i class="bi bi-list-ul me-2"></i> View Logs
                                        </a>
                                        <a asp-action="Settings" class="btn btn-primary rounded-pill px-4 shadow hover-lift fw-bold d-inline-flex align-items-center justify-content-center">
                                            <i class="bi bi-gear-fill me-2"></i> System Settings
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 p-4 rounded-4 border-0 shadow-sm d-flex align-items-start bg-soft-warning border-start border-warning border-5">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-4 me-3"></i>
                <div>
                    <h6 class="fw-bold text-dark mb-1">Confidentiality Reminder</h6>
                    <p class="mb-0 small text-muted">Accessing user data is subject to GDPR regulations. All sessions are monitored. Unauthorised disclosure is strictly prohibited.</p>
                </div>
            </div>
        </div>
    </div>
</div>
